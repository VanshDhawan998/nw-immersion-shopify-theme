{% comment %}
  NW Signature Saunas — 2×2 collection card grid
  Extracted from nw-landing-page.html design
{% endcomment %}

{%- style -%}
  /* ========== SIGNATURE SAUNAS ========== */
  .nw-saunas {
    padding: 60px 50px;
    max-width: 1440px;
    margin-inline: auto;
    font-family: 'Raleway', sans-serif;
  }

  .nw-saunas__title {
    font-size: 60px;
    font-weight: 700;
    color: {{ section.settings.title_color }};
    text-align: center;
    margin-bottom: 40px;
  }

  .nw-saunas__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 1340px;
    margin: 0 auto;
  }

  .nw-sauna-card {
    position: relative;
    height: 470px;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    display: block;
  }

  .nw-sauna-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .nw-sauna-card:hover img {
    transform: scale(1.05);
  }

  .nw-sauna-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(255,255,255,0.5), rgba(0,0,0,0.5));
    mix-blend-mode: multiply;
    border-radius: 12px;
  }

  .nw-sauna-card__label {
    position: absolute;
    bottom: 60px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 40px;
    font-weight: 600;
    color: #fff;
    white-space: nowrap;
    text-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1200px) {
    .nw-saunas { padding: 60px 36px; }
    .nw-saunas__title { font-size: 48px; }
  }

  @media (max-width: 1024px) {
    .nw-saunas { padding: 60px 30px; }
    .nw-saunas__title { font-size: 40px; }
    .nw-sauna-card { height: 350px; }
    .nw-sauna-card__label { font-size: 30px; bottom: 40px; }
  }

  @media (max-width: 768px) {
    .nw-saunas { padding: 40px 20px; }
    .nw-saunas__title { font-size: 32px; margin-bottom: 28px; }
    .nw-saunas__grid { grid-template-columns: 1fr; gap: 16px; }
    .nw-sauna-card { height: 280px; }
    .nw-sauna-card__label { font-size: 26px; bottom: 30px; }
  }

  @media (max-width: 480px) {
    .nw-sauna-card { height: 220px; }
    .nw-sauna-card__label { font-size: 22px; bottom: 24px; }
    .nw-saunas__title { font-size: 26px; margin-bottom: 20px; }
  }

  @media (max-width: 375px) {
    .nw-sauna-card { height: 200px; }
    .nw-sauna-card__label { font-size: 20px; }
    .nw-saunas__title { font-size: 22px; }
  }
{%- endstyle -%}

<div class="nw-saunas">
  <h2 class="nw-saunas__title">{{ section.settings.heading }}</h2>
  <div class="nw-saunas__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="nw-sauna-card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.label }}" loading="lazy">
        {%- else -%}
          <img src="{{ block.settings.image_url }}" alt="{{ block.settings.label }}" loading="lazy">
        {%- endif -%}
        <div class="nw-sauna-card__overlay"></div>
        <span class="nw-sauna-card__label">{{ block.settings.label }}</span>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "NW Signature Saunas",
  "tag": "section",
  "class": "nw-saunas-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NW Immersion Signature Saunas"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "sauna_card",
      "name": "Sauna Card",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image"
        },
        {
          "type": "url",
          "id": "image_url",
          "label": "Image URL (fallback if no image uploaded)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Outdoor Saunas"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NW Signature Saunas",
      "blocks": [
        { "type": "sauna_card", "settings": { "label": "Outdoor Saunas", "image_url": "https://www.figma.com/api/mcp/asset/0ef8dc2e-b643-44cb-9c73-5b0e8c4c6c0d" } },
        { "type": "sauna_card", "settings": { "label": "Indoor Saunas", "image_url": "https://www.figma.com/api/mcp/asset/d6f1c8a9-43fa-4fd4-902d-74463152633c" } },
        { "type": "sauna_card", "settings": { "label": "Tubs & Plunges", "image_url": "https://www.figma.com/api/mcp/asset/46cb5450-2456-472b-b8b9-3188e3b35fa8" } },
        { "type": "sauna_card", "settings": { "label": "Steam & Ice Suite", "image_url": "https://www.figma.com/api/mcp/asset/484f9b83-b7c2-4ffc-9803-16aec6635b1d" } }
      ]
    }
  ]
}
{% endschema %}
