{% comment %}
  NW Customize Experience — Full-width background image with text overlay
  Extracted from nw-landing-page.html design
{% endcomment %}

{%- style -%}
  /* ========== CUSTOMIZE EXPERIENCE ========== */
  .nw-customize {
    position: relative;
    min-height: 760px;
    overflow: hidden;
    font-family: 'Raleway', sans-serif;
  }

  .nw-customize__bg {
    position: absolute;
    inset: 0;
  }

  .nw-customize__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .nw-customize__content {
    position: relative;
    z-index: 2;
    padding: 210px 50px 210px 50px;
    max-width: 625px;
  }

  .nw-customize__title {
    font-size: 60px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    line-height: 1.15;
    margin-bottom: 30px;
  }

  .nw-customize__text {
    font-size: 18px;
    font-weight: 400;
    color: {{ section.settings.text_color }};
    line-height: 50px;
    margin-bottom: 36px;
    margin-left: 20px;
  }

  .nw-customize__btn {
    display: inline-flex;
    align-items: center;
    padding: 20px 40px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    font-size: 16px;
    font-weight: 700;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    margin-left: 20px;
    text-decoration: none;
  }

  .nw-customize__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.25);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1200px) {
    .nw-customize__title { font-size: 48px; }
  }

  @media (max-width: 1024px) {
    .nw-customize { min-height: 600px; }
    .nw-customize__content { padding: 140px 30px; }
    .nw-customize__title { font-size: 42px; }
    .nw-customize__text { line-height: 32px; margin-left: 0; }
    .nw-customize__btn { margin-left: 0; }
  }

  @media (max-width: 768px) {
    .nw-customize { min-height: auto; }
    .nw-customize__content { max-width: 100%; padding: 80px 20px; }
    .nw-customize__title { font-size: 32px; }
    .nw-customize__title br { display: none; }
    .nw-customize__text { font-size: 16px; line-height: 28px; margin-left: 0; margin-bottom: 24px; }
    .nw-customize__btn { margin-left: 0; padding: 14px 28px; }
  }

  @media (max-width: 480px) {
    .nw-customize__content { padding: 60px 20px; }
    .nw-customize__title { font-size: 26px; }
    .nw-customize__text { font-size: 14px; line-height: 24px; }
  }

  @media (max-width: 375px) {
    .nw-customize__title { font-size: 22px; }
  }
{%- endstyle -%}

<section class="nw-customize">
  <div class="nw-customize__bg">
    {%- if section.settings.background_image != blank -%}
      <img src="{{ section.settings.background_image | image_url: width: 1920 }}" alt="{{ section.settings.heading }}" loading="lazy">
    {%- else -%}
      <img src="{{ section.settings.background_image_url }}" alt="{{ section.settings.heading }}" loading="lazy">
    {%- endif -%}
  </div>
  <div class="nw-customize__content">
    <h2 class="nw-customize__title">{{ section.settings.heading }}</h2>
    <p class="nw-customize__text">{{ section.settings.subtext }}</p>
    {%- if section.settings.button_text != blank -%}
      <a href="{{ section.settings.button_link }}" class="nw-customize__btn">{{ section.settings.button_text }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "NW Customize Experience",
  "tag": "section",
  "class": "nw-customize-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customizing Your Experience"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Compare features, test color combos, and find the sauna that fits your life best."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "background_image_url",
      "label": "Background image URL (fallback)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Compare Saunas"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "NW Customize Experience",
      "settings": {
        "heading": "Customizing Your Experience",
        "subtext": "Compare features, test color combos, and find the sauna that fits your life best.",
        "background_image_url": "https://www.figma.com/api/mcp/asset/b4644235-56d1-4ed6-82e0-b642783622ce"
      }
    }
  ]
}
{% endschema %}
