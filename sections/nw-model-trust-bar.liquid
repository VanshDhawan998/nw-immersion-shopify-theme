{% comment %}
  NW Trust Bar — 3–column banner with editable items
  Extracted from nw-landing-page.html design
{% endcomment %}

{%- style -%}
  /* ========== MODEL TRUST BAR ========== */
  .nw-trust-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 3;
    background: {{ section.settings.background_color }};
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    padding: 35px 50px;
    max-width: 1340px;
    margin: -60px auto 0;
    border-radius: 12px;
    font-family: 'Raleway', sans-serif;
  }

  .nw-trust-bar__item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    font-size: 17px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    position: relative;
    padding: 0 24px;
    line-height: 1.3;
  }

  .nw-trust-bar__item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 44px;
    background: #eee;
  }

  /* ===== Responsive: Tablet ===== */
  @media (max-width: 1024px) {
    .nw-trust-bar {
      padding: 28px 32px;
      max-width: 95%;
      margin-top: -45px;
    }

    .nw-trust-bar__item {
      font-size: 15px;
      padding: 0 16px;
    }
  }

  /* ===== Responsive: Mobile – 2 column ===== */
  @media (max-width: 768px) {
    .nw-trust-bar {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      padding: 24px 28px;
      margin-top: -30px;
      border-radius: 10px;
    }

    .nw-trust-bar__item {
      font-size: 14px;
      padding: 14px 12px;
      justify-content: center;
      text-align: center;
      border-bottom: 1px solid #eee;
    }

    /* Odd items get a right border as column separator */
    .nw-trust-bar__item:nth-child(odd) {
      border-right: 1px solid #eee;
    }

    /* Remove the pseudo-element dividers at this breakpoint */
    .nw-trust-bar__item:not(:last-child)::after {
      display: none;
    }
  }

  /* ===== Responsive: Small phone – single column ===== */
  @media (max-width: 480px) {
    .nw-trust-bar {
      grid-template-columns: 1fr;
      padding: 16px 20px;
      margin-top: -20px;
      border-radius: 8px;
    }

    .nw-trust-bar__item {
      font-size: 13px;
      padding: 12px 0;
    }

    .nw-trust-bar__item:nth-child(odd) {
      border-right: none;
    }

    .nw-trust-bar__item:last-child {
      border-bottom: none;
    }
  }
{%- endstyle -%}

<div class="nw-trust-bar">
  {%- for block in section.blocks -%}
    <div class="nw-trust-bar__item" {{ block.shopify_attributes }}>
      {{ block.settings.text }}
    </div>
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "NW Trust Bar",
  "tag": "section",
  "class": "nw-trust-bar-section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "12+ Years of Craftsmanship"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NW Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "text": "12+ Years of Craftsmanship" } },
        { "type": "trust_item", "settings": { "text": "Continental US Shipping" } },
        { "type": "trust_item", "settings": { "text": "Same Day Parts Shipping" } }
      ]
    }
  ]
}
{% endschema %}
