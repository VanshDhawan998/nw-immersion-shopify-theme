{% comment %}
  NW Blog — 3-column blog card grid
  Extracted from nw-landing-page.html design
{% endcomment %}

{%- style -%}
  /* ========== OUR BLOG ========== */
  .nw-blog {
    padding: 80px 50px;
    max-width: 1440px;
    margin-inline: auto;
    font-family: 'Raleway', sans-serif;
  }

  .nw-blog__title {
    font-size: 60px;
    font-weight: 700;
    color: {{ section.settings.title_color }};
    text-align: center;
    margin-bottom: 50px;
  }

  .nw-blog__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 33px;
    max-width: 1340px;
    margin: 0 auto;
  }

  .nw-blog__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .nw-blog__card-image {
    position: relative;
    height: 295px;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .nw-blog__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .nw-blog__card:hover .nw-blog__card-image img {
    transform: scale(1.05);
  }

  .nw-blog__card-image .nw-blog__arrow {
    position: absolute;
    bottom: 20px;
    right: 20px;
    width: 40px;
    height: 40px;
    transition: transform 0.2s;
  }

  .nw-blog__card-image .nw-blog__arrow:hover {
    transform: scale(1.1);
  }

  .nw-blog__card-title {
    font-size: 24px;
    font-weight: 700;
    color: #000;
    line-height: 1.3;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1200px) {
    .nw-blog { padding: 80px 36px; }
    .nw-blog__title { font-size: 48px; }
  }

  @media (max-width: 1024px) {
    .nw-blog { padding: 60px 30px; }
    .nw-blog__title { font-size: 40px; }
    .nw-blog__card-image { height: 230px; }
    .nw-blog__card-title { font-size: 20px; }
  }

  @media (max-width: 768px) {
    .nw-blog { padding: 50px 20px; }
    .nw-blog__title { font-size: 32px; margin-bottom: 28px; }
    .nw-blog__grid { grid-template-columns: 1fr 1fr; gap: 20px; }
    .nw-blog__card-image { height: 200px; }
    .nw-blog__card-title { font-size: 18px; }
  }

  @media (max-width: 480px) {
    .nw-blog__title { font-size: 26px; margin-bottom: 20px; }
    .nw-blog__grid { grid-template-columns: 1fr; }
    .nw-blog__card-image { height: 220px; }
    .nw-blog__card-title { font-size: 18px; }
  }
{%- endstyle -%}

<div class="nw-blog">
  <h2 class="nw-blog__title">{{ section.settings.heading }}</h2>
  <div class="nw-blog__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="nw-blog__card" {{ block.shopify_attributes }}>
        <div class="nw-blog__card-image">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title }}" loading="lazy">
          {%- else -%}
            <img src="{{ block.settings.image_url }}" alt="{{ block.settings.title }}" loading="lazy">
          {%- endif -%}
          {%- if section.settings.arrow_icon_url != blank -%}
            <img class="nw-blog__arrow" src="{{ section.settings.arrow_icon_url }}" alt="Read more">
          {%- endif -%}
        </div>
        <h3 class="nw-blog__card-title">{{ block.settings.title }}</h3>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "NW Blog",
  "tag": "section",
  "class": "nw-blog-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Blog"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "arrow_icon_url",
      "label": "Arrow icon URL"
    }
  ],
  "blocks": [
    {
      "type": "blog_card",
      "name": "Blog Card",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Blog Post Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL (fallback)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NW Blog",
      "settings": {
        "heading": "Our Blog",
        "arrow_icon_url": "https://www.figma.com/api/mcp/asset/2322027e-6126-44ae-8944-72247a865c5a"
      },
      "blocks": [
        { "type": "blog_card", "settings": { "title": "Steven Ogg's Morning Ritual", "image_url": "https://www.figma.com/api/mcp/asset/696a4ac8-6ba8-434e-b2ac-eedaac3c2862" } },
        { "type": "blog_card", "settings": { "title": "How Kara Transformed Her Evening Routine With a Sauna", "image_url": "https://www.figma.com/api/mcp/asset/3c09303f-be13-4b79-a9c8-1231908cf8ff" } },
        { "type": "blog_card", "settings": { "title": "The Ultimate guide to Sauna", "image_url": "https://www.figma.com/api/mcp/asset/d18a9a3f-2ff9-4edf-a1b5-baf89deff91d" } }
      ]
    }
  ]
}
{% endschema %}
