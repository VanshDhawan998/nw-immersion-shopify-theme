<!-- Two Cards Section - Shopify Liquid Section -->
<style>
  /* Google Fonts Import */
  @import url('https://fonts.googleapis.com/css2?family=Quando&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap');

  /* Section CSS Variables from Shopify Settings */
  #two-cards-section-{{ section.id }} {
    --font-heading: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    --font-body: {{ section.settings.body_font.family }}, {{ section.settings.body_font.fallback_families }};
    --font-button: {{ section.settings.button_font.family }}, {{ section.settings.button_font.fallback_families }};

    --color-dark: {{ section.settings.text_color }};
    --color-accent: {{ section.settings.button_bg_color }};
    --color-card-bg: {{ section.settings.card_bg_color }};
    --color-section-bg: {{ section.settings.section_bg_color }};

    --card-heading-size: {{ section.settings.heading_font_size }}px;
    --card-heading-weight: {{ section.settings.heading_font_weight }};
    --card-heading-line: {{ section.settings.heading_line_height }};
    --card-text-size: {{ section.settings.text_font_size }}px;
    --card-text-weight: {{ section.settings.text_font_weight }};
    --card-text-line: {{ section.settings.text_line_height }};

    --btn-size: {{ section.settings.button_font_size }}px;
    --btn-padding: {{ section.settings.button_padding_vertical }}px {{ section.settings.button_padding_horizontal }}px;
    --btn-line: {{ section.settings.button_line_height }};

    --section-py: {{ section.settings.section_padding_top }}px;
    --section-pb: {{ section.settings.section_padding_bottom }}px;
    --section-px: {{ section.settings.section_padding_horizontal }}px;
    --card-padding: {{ section.settings.card_padding }}px;
    --card-gap: {{ section.settings.card_gap }}px;
    --content-gap: {{ section.settings.content_gap }}px;
    --max-width: {{ section.settings.max_width }}px;
  }

  /* CSS Reset for this section */
  #two-cards-section-{{ section.id }} * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* Two Cards Section Styles */
  #two-cards-section-{{ section.id }} .two-cards-section {
    width: 100%;
    background: var(--color-section-bg);
    padding: var(--section-py) var(--section-px) var(--section-pb);
  }

  #two-cards-section-{{ section.id }} .cards-container {
    display: flex;
    gap: var(--card-gap);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  #two-cards-section-{{ section.id }} .card {
    flex: 1;
    background: var(--color-card-bg);
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: var(--card-padding);
    display: flex;
    flex-direction: column;
    gap: var(--content-gap);
  }

  #two-cards-section-{{ section.id }} .card h2 {
    font-family: var(--font-heading);
    font-size: var(--card-heading-size);
    font-weight: var(--card-heading-weight);
    line-height: var(--card-heading-line);
    color: var(--color-dark);
    margin: 0;
  }

  #two-cards-section-{{ section.id }} .card p {
    font-family: var(--font-body);
    font-size: var(--card-text-size);
    font-weight: var(--card-text-weight);
    line-height: var(--card-text-line);
    color: var(--color-dark);
    margin: 0;
  }

  #two-cards-section-{{ section.id }} .card-btn {
    background: var(--color-accent);
    color: {{ section.settings.button_text_color }};
    border-radius: {{ section.settings.button_border_radius }}px;
    text-decoration: none;
    font-family: var(--font-button);
    font-weight: {{ section.settings.button_font_weight }};
    font-size: var(--btn-size);
    padding: var(--btn-padding);
    line-height: var(--btn-line);
    transition: 0.3s ease;
    display: inline-block;
    border: 1px solid var(--color-accent);
    width: fit-content;
    margin-top: {{ section.settings.button_margin_top }}px;
  }

  #two-cards-section-{{ section.id }} .card-btn:hover {
    background: {{ section.settings.button_hover_bg_color }};
    color: {{ section.settings.button_hover_text_color }};
    {% if section.settings.button_hover_lift %}
      transform: translateY(-2px);
    {% endif %}
  }

  /* Responsive Design */
  @media (max-width: 992px) {
    #two-cards-section-{{ section.id }} .cards-container {
      flex-direction: column;
      gap: {{ section.settings.mobile_card_gap | default: 25 }}px;
    }

    #two-cards-section-{{ section.id }} .card h2 {
      font-size: calc(var(--card-heading-size) * {{ section.settings.tablet_heading_scale | divided_by: 100.0 }});
    }
  }

  @media (max-width: 768px) {
    #two-cards-section-{{ section.id }} .two-cards-section {
      padding: calc(var(--section-py) * {{ section.settings.mobile_padding_scale | divided_by: 100.0 }}) calc(var(--section-px) * {{ section.settings.mobile_padding_scale | divided_by: 100.0 }}) calc(var(--section-pb) * {{ section.settings.mobile_padding_scale | divided_by: 100.0 }});
    }

    #two-cards-section-{{ section.id }} .card {
      padding: calc(var(--card-padding) * {{ section.settings.mobile_card_padding_scale | divided_by: 100.0 }});
    }

    #two-cards-section-{{ section.id }} .card h2 {
      font-size: calc(var(--card-heading-size) * {{ section.settings.mobile_heading_scale | divided_by: 100.0 }});
      line-height: calc(var(--card-heading-line) * {{ section.settings.mobile_heading_scale | divided_by: 100.0 }});
    }

    #two-cards-section-{{ section.id }} .card p {
      font-size: calc(var(--card-text-size) * {{ section.settings.mobile_text_scale | divided_by: 100.0 }});
      line-height: calc(var(--card-text-line) * {{ section.settings.mobile_text_scale | divided_by: 100.0 }});
    }
  }

  @media (max-width: 576px) {
    #two-cards-section-{{ section.id }} .card h2 {
      font-size: calc(var(--card-heading-size) * {{ section.settings.small_mobile_heading_scale | divided_by: 100.0 }});
      line-height: calc(var(--card-heading-line) * {{ section.settings.small_mobile_heading_scale | divided_by: 100.0 }});
      {% if section.settings.mobile_center_heading %}
        text-align: center;
      {% endif %}
    }

    #two-cards-section-{{ section.id }} .card p {
      font-size: calc(var(--card-text-size) * {{ section.settings.small_mobile_text_scale | divided_by: 100.0 }});
      line-height: calc(var(--card-text-line) * {{ section.settings.small_mobile_text_scale | divided_by: 100.0 }});
      {% if section.settings.mobile_center_text %}
        text-align: center;
      {% endif %}
    }

    #two-cards-section-{{ section.id }} .card-btn {
      {% if section.settings.mobile_full_width_button %}
        width: 100%;
        text-align: center;
      {% endif %}
      padding: {{ section.settings.mobile_button_padding_vertical | default: 14 }}px {{ section.settings.mobile_button_padding_horizontal | default: 20 }}px;
    }
  }

  @media (max-width: 480px) {
    #two-cards-section-{{ section.id }} .card h2 {
      font-size: calc(var(--card-heading-size) * {{ section.settings.extra_small_heading_scale | divided_by: 100.0 }});
    }

    #two-cards-section-{{ section.id }} .card {
      padding: calc(var(--card-padding) * {{ section.settings.extra_small_card_padding_scale | divided_by: 100.0 }});
    }
  }
</style>

<section class="two-cards-section" id="two-cards-section-{{ section.id }}">
  <div class="cards-container">
    {% comment %} Render each card as a block {% endcomment %}
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'card' %}
          <div class="card" {{ block.shopify_attributes }}>
            {% if block.settings.heading != blank %}
              <h2>{{ block.settings.heading }}</h2>
            {% endif %}
            
            {% if block.settings.text != blank %}
              <p>{{ block.settings.text }}</p>
            {% endif %}
            
            {% if block.settings.button_text != blank %}
              <a href="{{ block.settings.button_link | default: '#' }}" class="card-btn">
                {{ block.settings.button_text }}
              </a>
            {% endif %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Two Cards Section",
  "tag": "section",
  "class": "two-cards-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum Container Width",
      "min": 1200,
      "max": 1800,
      "step": 50,
      "default": 1650,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap Between Cards",
      "min": 15,
      "max": 60,
      "step": 5,
      "default": 30,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Content Gap Inside Cards",
      "min": 16,
      "max": 40,
      "step": 2,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#F5F0E8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#252220"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#546659"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Button Hover Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button Hover Text Color",
      "default": "#546659"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font Size",
      "min": 24,
      "max": 48,
      "step": 2,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_weight",
      "label": "Heading Font Weight",
      "min": 400,
      "max": 800,
      "step": 100,
      "default": 700
    },
    {
      "type": "select",
      "id": "heading_line_height",
      "label": "Heading Line Height",
      "options": [
        { "value": "1.1", "label": "1.1" },
        { "value": "1.2", "label": "1.2" },
        { "value": "1.25", "label": "1.25" },
        { "value": "1.3", "label": "1.3" },
        { "value": "1.4", "label": "1.4" }
      ],
      "default": "1.25"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body Text Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "text_font_size",
      "label": "Text Font Size",
      "min": 14,
      "max": 20,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "text_font_weight",
      "label": "Text Font Weight",
      "min": 300,
      "max": 600,
      "step": 100,
      "default": 400
    },
    {
      "type": "select",
      "id": "text_line_height",
      "label": "Text Line Height",
      "options": [
        { "value": "1.3", "label": "1.3" },
        { "value": "1.4", "label": "1.4" },
        { "value": "1.5", "label": "1.5" },
        { "value": "1.6", "label": "1.6" }
      ],
      "default": "1.5"
    },
    {
      "type": "font_picker",
      "id": "button_font",
      "label": "Button Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button Font Size",
      "min": 14,
      "max": 18,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_font_weight",
      "label": "Button Font Weight",
      "min": 400,
      "max": 800,
      "step": 100,
      "default": 700
    },
    {
      "type": "select",
      "id": "button_line_height",
      "label": "Button Line Height",
      "options": [
        { "value": "1.2", "label": "1.2" },
        { "value": "1.3", "label": "1.3" },
        { "value": "1.4", "label": "1.4" },
        { "value": "1.5", "label": "1.5" }
      ],
      "default": "1.2"
    },
    {
      "type": "header",
      "content": "Spacing & Padding"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section Top Padding",
      "min": 40,
      "max": 150,
      "step": 10,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section Bottom Padding",
      "min": 40,
      "max": 150,
      "step": 10,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "label": "Section Horizontal Padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card Padding",
      "min": 20,
      "max": 60,
      "step": 5,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card Border Radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Button Vertical Padding",
      "min": 8,
      "max": 20,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Button Horizontal Padding",
      "min": 16,
      "max": 40,
      "step": 2,
      "default": 30,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button Border Radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_margin_top",
      "label": "Button Top Margin",
      "min": 0,
      "max": 20,
      "step": 2,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "button_hover_lift",
      "label": "Button Hover Lift Effect",
      "default": true
    },
    {
      "type": "header",
      "content": "Responsive - Tablet (992px and below)"
    },
    {
      "type": "range",
      "id": "mobile_card_gap",
      "label": "Mobile Card Gap",
      "min": 15,
      "max": 40,
      "step": 5,
      "default": 25,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "tablet_heading_scale",
      "label": "Tablet Heading Scale",
      "min": 70,
      "max": 100,
      "step": 5,
      "default": 85,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Responsive - Mobile (768px and below)"
    },
    {
      "type": "range",
      "id": "mobile_padding_scale",
      "label": "Mobile Padding Scale",
      "min": 60,
      "max": 100,
      "step": 5,
      "default": 75,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "mobile_card_padding_scale",
      "label": "Mobile Card Padding Scale",
      "min": 60,
      "max": 100,
      "step": 5,
      "default": 80,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "mobile_heading_scale",
      "label": "Mobile Heading Scale",
      "min": 60,
      "max": 90,
      "step": 5,
      "default": 75,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "mobile_text_scale",
      "label": "Mobile Text Scale",
      "min": 80,
      "max": 100,
      "step": 5,
      "default": 90,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Responsive - Small Mobile (576px and below)"
    },
    {
      "type": "range",
      "id": "small_mobile_heading_scale",
      "label": "Small Mobile Heading Scale",
      "min": 50,
      "max": 80,
      "step": 5,
      "default": 65,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "small_mobile_text_scale",
      "label": "Small Mobile Text Scale",
      "min": 70,
      "max": 95,
      "step": 5,
      "default": 85,
      "unit": "%"
    },
    {
      "type": "checkbox",
      "id": "mobile_center_heading",
