      "type": "range",
      "id": "extra_small_heading_scale",
      "label": "Extra Small Heading Scale",
      "min": 40,
      "max": 70,
      "step": 5,
      "default": 55,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "extra_small_card_padding_scale",
