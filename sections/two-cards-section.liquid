  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Card Heading",
          "default": "Card Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Card Text",
          "default": "Add your card description text here. This text will appear below the heading."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Two Cards Section",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "heading": "Bookings For Mid 2026 Now Open",
            "text": "We're now scheduling Bespoke sauna builds into mid 2026. With only a limited number taken on each year, reserving early ensures your project is secured. A 25% non-refundable deposit holds your spot, with 50% due when your build begins and the remaining 25% prior to shipping. Place your order online and our team will follow up to confirm every detail, provide your contract for signature, and issue your invoice.",
            "button_text": "Reserve My Bespoke Build"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading": "What A Bespoke Sauna Feels Like",
            "text": "A Bespoke sauna is a space designed around you. The scent of cedar as you step inside, the way the benches fit your posture, the glow of light that sets the tone. Every detail reflects your vision. Pair it with cold immersion for contrast, and you'll create a wellness routine that feels both grounding and transformative.",
            "button_text": "Start Designing My Sauna"
          }
        }
      ]
    }
  ]
}
{% endschema %}