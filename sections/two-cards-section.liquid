      "default": true
    },
    {
      "type": "checkbox",
      "id": "mobile_center_text",
      "label": "Center Text on Small Mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "mobile_full_width_button",
      "label": "Full Width Buttons on Small Mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "mobile_button_padding_vertical",
      "label": "Mobile Button Vertical Padding",
      "min": 10,
      "max": 20,
      "step": 2,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_button_padding_horizontal",
      "label": "Mobile Button Horizontal Padding",
      "min": 16,
      "max": 30,
      "step": 2,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "header",
