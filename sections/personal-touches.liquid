<!-- Personal Touches Section -->
<section class="personal-touches-section" 
         style="
           margin: {{ section.settings.margin_top }}px {{ section.settings.margin_right }}px {{ section.settings.margin_bottom }}px {{ section.settings.margin_left }}px;
           padding: {{ section.settings.section_padding_top }}px {{ section.settings.section_padding_right }}px {{ section.settings.section_padding_bottom }}px {{ section.settings.section_padding_left }}px;
         ">
  
  <!-- Main Content Container -->
  <div class="personal-container">
    
    <div class="personal-layout">
      
      <!-- Left Column - Main Content -->
      <div class="main-content">
        
        <!-- Main Heading -->
        {% if section.settings.main_heading != blank %}
          <h2 class="main-heading">{{ section.settings.main_heading }}</h2>
        {% endif %}

        <!-- Main Description -->
        {% if section.settings.main_description != blank %}
          <p class="main-description">{{ section.settings.main_description }}</p>
        {% endif %}

        <!-- Call to Action Button -->
        {% if section.settings.button_text != blank and section.settings.button_url != blank %}
          <a href="{{ section.settings.button_url }}" 
             class="cta-button"
             style="
               background-color: {{ section.settings.button_background_color }};
               color: {{ section.settings.button_text_color }};
               border-color: {{ section.settings.button_background_color }};
             ">
            {{ section.settings.button_text }}
          </a>
        {% endif %}
        
      </div>

      <!-- Right Column - Feature Cards -->
      <div class="features-column">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            <div class="personal-feature-card" 
                 {{ block.shopify_attributes }}
                 style="
                   background-color: {{ section.settings.card_background_color }};
                   border-radius: {{ section.settings.card_border_radius }}px;
                 ">
              
              {% if block.settings.feature_title != blank %}
                <h3 class="feature-title">{{ block.settings.feature_title }}</h3>
              {% endif %}
              
              {% if block.settings.feature_description != blank %}
                <p class="feature-description">{{ block.settings.feature_description }}</p>
              {% endif %}
              
            </div>
          {% endfor %}
        {% endif %}
      </div>
      
    </div>
  </div>
</section>

<style>
  /* Import Google Fonts */
  @import url('https://fonts.googleapis.com/css2?family=Quando&family=Inter:wght@400;500;600;700&display=swap');

  /* Section Styles */
  .personal-touches-section {
    font-family: 'Quando', serif;
    color: {{ section.settings.text_color | default: '#252220' }};
    min-height: auto;
    display: flex;
    align-items: center;
    max-width:1670PX;
    justify-self: center;
  }

  .personal-container {
    max-width: {{ section.settings.max_width | default: 1670 }}px;
    margin: 0 auto;
    padding: {{ section.settings.container_padding_top }}px {{ section.settings.container_padding_right }}px {{ section.settings.container_padding_bottom }}px {{ section.settings.container_padding_left }}px;
    width: 100%;
  }

  .personal-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.column_gap | default: 70 }}px;
    align-items: center;
  }

  /* Left Column - Main Content */
  .main-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .main-heading {
    font-family: sans-serif;
    font-size: {{ section.settings.main_heading_size | default: 40 }}px;
    font-weight: 700;
    line-height: 1.25;
    color: {{ section.settings.heading_color | default: '#252220' }};
    margin-bottom: 30px;
    letter-spacing: normal;
  }

  .main-description {
    font-family: 'Quando', serif;
    font-size: {{ section.settings.text_size | default: 18 }}px;
    font-weight: 400;
    line-height: 1.56;
    color: {{ section.settings.text_color | default: '#252220' }};
    margin-bottom: {{ section.settings.button_margin_top | default: 50 }}px;
    max-width: {{ section.settings.description_max_width | default: 500 }}px;
  }

  .cta-button {
    display: inline-block;
    background-color: {{ section.settings.button_background_color | default: '#546659' }};
    color: {{ section.settings.button_text_color | default: 'white' }};
    padding: {{ section.settings.button_padding_vertical | default: 15 }}px {{ section.settings.button_padding_horizontal | default: 35 }}px;
    border-radius: {{ section.settings.button_border_radius | default: 20 }}px;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: {{ section.settings.button_text_size | default: 18 }}px;
    font-weight: 700;
    transition: all 0.3s ease;
    border: 1px solid {{ section.settings.button_background_color | default: '#546659' }};
    line-height: 1.4;
    text-align: center;
    white-space: nowrap;
    cursor: pointer;
    vertical-align: middle;
    width: fit-content;
  }

  .cta-button:hover {
    background-color: {{ section.settings.button_hover_background | default: '#ffffff' }};
    color: {{ section.settings.button_hover_text_color | default: '#546659' }};
    border-color: {{ section.settings.button_background_color | default: '#546659' }};
  }

  /* Right Column - Feature Cards */
  .features-column {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.card_gap | default: 60 }}px;
  }

  .personal-feature-card {
    background-color: {{ section.settings.card_background_color | default: '#fbefdb' }};
    padding: {{ section.settings.card_padding | default: 1 }}px;
    border-radius: {{ section.settings.card_border_radius | default: 20 }}px;
    transition: transform 0.2s ease;
    width: 100%;
  }

  .personal-feature-card:hover {
    transform: translateY(-2px);
  }

  .feature-title {
    font-family: sans-serif;
    font-size: {{ section.settings.card_title_size | default: 24 }}px;
    font-weight: 600;
    line-height: 1.17;
    color: {{ section.settings.heading_color | default: '#252220' }};
    margin-bottom: 20px;
    letter-spacing: normal;
  }

  .feature-description {
    font-family: 'Quando', serif;
    font-size: {{ section.settings.card_text_size | default: 18 }}px;
    font-weight: 400;
    line-height: 1.56;
    color: {{ section.settings.text_color | default: '#252220' }};
    max-width: 100%;
  }

  /* Responsive Design */
    @media (max-width: 992px) {
    .personal-touches-section {
      margin: {{ section.settings.margin_top | divided_by: 1.5 | round }}px {{ section.settings.margin_right }}px {{ section.settings.margin_bottom }}px {{ section.settings.margin_left }}px;
      padding: {{ section.settings.section_padding_top | divided_by: 1.5 | round }}px {{ section.settings.section_padding_right }}px {{ section.settings.section_padding_bottom | divided_by: 1.5 | round }}px {{ section.settings.section_padding_left }}px;
    }
    
    .personal-container {
      padding: {{ section.settings.container_padding_top | divided_by: 1.5 | round }}px {{ section.settings.container_padding_right | divided_by: 2 | round }}px {{ section.settings.container_padding_bottom | divided_by: 1.5 | round }}px {{ section.settings.container_padding_left | divided_by: 2 | round }}px;
     max-widthL 1670px;
    }
    
    .personal-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    
    .main-content {
      padding-right: 0;
    }
    
    .main-heading {
      font-size: {{ section.settings.main_heading_size | default: 40 | times: 0.8 | round }}px;
      margin-bottom: 24px;
    }
    
    .main-description {
      margin-bottom: 32px;
      max-width: 100%;
    }
    
    .features-column {
      gap: 32px;
    }
  }

  @media (max-width: 768px) {
    .main-heading {
      font-size: {{ section.settings.main_heading_size | default: 40 | times: 0.7 | round }}px;
      line-height: 1.3;
    }
    
    .main-description {
      font-size: {{ section.settings.text_size | default: 18 | minus: 2 }}px;
    }
    
    .cta-button {
      padding: {{ section.settings.button_padding_vertical | default: 15 | minus: 3 }}px {{ section.settings.button_padding_horizontal | default: 35 | minus: 7 }}px;
      font-size: {{ section.settings.button_text_size | default: 18 | minus: 2 }}px;
    }
    
    .feature-title {
      font-size: {{ section.settings.card_title_size | default: 24 | minus: 2 }}px;
      margin-bottom: 16px;
    }
    
    .feature-description {
      font-size: {{ section.settings.card_text_size | default: 18 | minus: 2 }}px;
    }
    
    .features-column {
      gap: 30px;
    }
  }
</style>

