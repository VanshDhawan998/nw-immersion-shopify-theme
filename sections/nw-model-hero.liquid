{% comment %}
  NW Model Hero — Full-height hero with background image, overlay, model title,
  subtitle, and trust bar pill items.
  Reusable for Silver Star, Loowit, and future models.
{% endcomment %}

{%- style -%}
  /* ========== MODEL HERO ========== */
  .nw-model-hero {
    position: relative;
    height: 780px;
    margin-top: -60px; /* nav is position:absolute (60px), let it overlay the hero */
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Raleway', sans-serif;
  }

  .nw-model-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .nw-model-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .nw-model-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 1;
  }

  /* Radial glow effect (matches HTML hero__glow) */
  .nw-model-hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 80%, rgba(255, 255, 255, 0.06) 0%, transparent 70%);
    z-index: 1;
    pointer-events: none;
  }

  .nw-model-hero__content {
    position: relative;
    z-index: 5;
    text-align: center;
    max-width: 1400px;
    padding: 120px 50px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 78px;
  }

  .nw-model-hero__text-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;
    max-width: 1343px;
  }

  .nw-model-hero__title {
    font-family: 'Raleway', sans-serif;
    font-size: 60px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    line-height: 1.15;
    text-align: center;
    margin: 0;
  }

  .nw-model-hero__subtitle {
    font-family: 'Raleway', sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: {{ section.settings.text_color }};
    line-height: 28px;
    text-align: center;
    max-width: 1400px;
    margin: 0;
  }

  .nw-model-hero__trust-bar {
    display: flex;
    align-items: center;
    gap: 39px;
  }

  .nw-model-hero__trust-item {
    font-family: 'Raleway', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    white-space: nowrap;
  }

  .nw-model-hero__trust-sep {
    width: 0;
    height: 42px;
    border-left: 1px solid rgba(255, 255, 255, 0.25);
    opacity: 1;
  }

  /* ===== CTA Button ===== */
  .nw-model-hero__cta {
    display: inline-block;
    background: #fff;
    color: #000;
    padding: 20px 40px;
    border-radius: 4px;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .nw-model-hero__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.25);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1200px) {
    .nw-model-hero__content { padding: 100px 50px; }
    .nw-model-hero__title { font-size: 48px; }
  }

  @media (max-width: 1024px) {
    .nw-model-hero { height: 640px; }
    .nw-model-hero__content { padding: 80px 40px; gap: 50px; }
    .nw-model-hero__title { font-size: 40px; }
    .nw-model-hero__trust-bar { flex-wrap: wrap; justify-content: center; gap: 20px; }
    .nw-model-hero__trust-item { font-size: 16px; }
    .nw-model-hero__trust-sep { height: 30px; }
    .nw-model-hero__cta { padding: 16px 32px; font-size: 15px; }
  }

  @media (max-width: 768px) {
    .nw-model-hero { height: 520px; margin-top: -60px; }
    .nw-model-hero__content { padding: 60px 20px; gap: 40px; }
    .nw-model-hero__title { font-size: 32px; }
    .nw-model-hero__subtitle { font-size: 16px; line-height: 26px; }
    .nw-model-hero__trust-bar { flex-direction: column; gap: 12px; }
    .nw-model-hero__trust-sep { display: none; }
    .nw-model-hero__cta { padding: 14px 28px; font-size: 14px; }
  }

  @media (max-width: 480px) {
    .nw-model-hero { height: 440px; }
    .nw-model-hero__title { font-size: 26px; }
    .nw-model-hero__subtitle { font-size: 14px; line-height: 22px; }
    .nw-model-hero__trust-item { font-size: 14px; }
    .nw-model-hero__cta { padding: 12px 24px; }
  }
{%- endstyle -%}

<section class="nw-model-hero">
  <div class="nw-model-hero__bg">
    {%- if section.settings.background_image != blank -%}
      <img src="{{ section.settings.background_image | image_url: width: 1920 }}" alt="{{ section.settings.heading }}" loading="eager" fetchpriority="high">
    {%- elsif section.settings.background_image_url != blank -%}
      <img src="{{ section.settings.background_image_url }}" alt="{{ section.settings.heading }}" loading="eager" fetchpriority="high">
    {%- endif -%}
  </div>
  <div class="nw-model-hero__overlay"></div>

  <div class="nw-model-hero__content">
    <div class="nw-model-hero__text-wrap">
      <h1 class="nw-model-hero__title">{{ section.settings.heading }}</h1>
      {%- if section.settings.subheading != blank -%}
        <p class="nw-model-hero__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="nw-model-hero__trust-bar">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_item' -%}
            {%- unless forloop.first -%}
              <span class="nw-model-hero__trust-sep" aria-hidden="true"></span>
            {%- endunless -%}
            <span class="nw-model-hero__trust-item" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "NW Model Hero",
  "tag": "section",
  "class": "nw-model-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Silver Star Sauna Model – Handcrafted Luxury Saunas"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our most popular model, the Silver Star is built by hand..."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "url",
      "id": "background_image_url",
      "label": "Background Image URL (fallback)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FCFCFC"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Item Text",
          "default": "12+ Years of Craftsmanship"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NW Model Hero",
      "blocks": [
        { "type": "trust_item", "settings": { "text": "12+ Years of Craftsmanship" } },
        { "type": "trust_item", "settings": { "text": "Continental US Shipping" } },
        { "type": "trust_item", "settings": { "text": "Same-Day Parts Shipping" } }
      ]
    }
  ]
}
{% endschema %}
