{% comment %}
  NW Model Process — "Your Journey Into Heat and Stillness" step cards
  5-column grid showing the order-to-delivery process.
{% endcomment %}

{%- style -%}
  /* ========== MODEL PROCESS ========== */
  .nw-model-process {
    padding: 120px 100px;
    font-family: 'Raleway', sans-serif;
    background: {{ section.settings.background_color }};
  }

  .nw-model-process__header {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 60px;
  }

  .nw-model-process__title {
    font-family: 'Raleway', sans-serif;
    font-size: 40px;
    font-weight: 700;
    color: {{ section.settings.title_color }};
    line-height: 50px;
    margin: 0;
  }

  .nw-model-process__subtitle {
    font-family: 'Raleway', sans-serif;
    font-size: 18px;
    color: {{ section.settings.text_color }};
    line-height: 28px;
    margin: 0;
    max-width: 700px;
  }

  .nw-model-process__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 30px;
  }

  .nw-model-process__card {
    background: {{ section.settings.card_bg }};
    border-radius: 8px;
    padding: 40px 30px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    min-height: 340px;
  }

  .nw-model-process__step-num {
    font-family: 'Raleway', sans-serif;
    font-size: 40px;
    font-weight: 700;
    color: {{ section.settings.accent_color }};
    line-height: normal;
  }

  .nw-model-process__step-title {
    font-family: 'Raleway', sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: {{ section.settings.card_title_color }};
    line-height: normal;
    margin: 0;
  }

  .nw-model-process__step-text {
    font-family: 'Raleway', sans-serif;
    font-size: 18px;
    color: {{ section.settings.card_text_color }};
    line-height: 28px;
    margin: 0;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1200px) {
    .nw-model-process { padding: 100px 60px; }
    .nw-model-process__grid { grid-template-columns: repeat(3, 1fr); gap: 25px; }
  }

  @media (max-width: 1024px) {
    .nw-model-process { padding: 80px 40px; }
    .nw-model-process__title { font-size: 34px; line-height: 44px; }
    .nw-model-process__grid { grid-template-columns: repeat(3, 1fr); }
    .nw-model-process__card { padding: 30px 24px; min-height: 280px; }
    .nw-model-process__step-num { font-size: 34px; }
    .nw-model-process__step-title { font-size: 20px; }
  }

  @media (max-width: 768px) {
    .nw-model-process { padding: 60px 20px; }
    .nw-model-process__grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .nw-model-process__title { font-size: 28px; line-height: 38px; }
    .nw-model-process__card { min-height: auto; }
  }

  @media (max-width: 480px) {
    .nw-model-process__grid { grid-template-columns: 1fr; }
    .nw-model-process__title { font-size: 24px; line-height: 34px; }
    .nw-model-process__step-text { font-size: 16px; line-height: 26px; }
  }
{%- endstyle -%}

<section class="nw-model-process">
  <div class="nw-model-process__header">
    <h2 class="nw-model-process__title">{{ section.settings.heading }}</h2>
    {%- if section.settings.subtitle != blank -%}
      <p class="nw-model-process__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>

  <div class="nw-model-process__grid">
    {%- assign step_counter = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'step' -%}
        {%- assign step_counter = step_counter | plus: 1 -%}
        <div class="nw-model-process__card" {{ block.shopify_attributes }}>
          <span class="nw-model-process__step-num">{{ step_counter }}</span>
          <h3 class="nw-model-process__step-title">{{ block.settings.title }}</h3>
          <p class="nw-model-process__step-text">{{ block.settings.description }}</p>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "NW Model Process",
  "tag": "section",
  "class": "nw-model-process-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Journey Into Heat and Stillness"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FCFCFC"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#252220"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#252220"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#fbefdb"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card Title Color",
      "default": "#252220"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text Color",
      "default": "#252220"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Step Number Color",
      "default": "#546659"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Process Step",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Consultation"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description",
          "default": "We start with a conversation about your space, preferences, and goals."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NW Model Process",
      "blocks": [
        { "type": "step", "settings": { "title": "Consultation", "description": "We start with a conversation about your space, preferences, and goals." } },
        { "type": "step", "settings": { "title": "Custom Quote", "description": "Receive a clear, transparent quote tailored to your selections." } },
        { "type": "step", "settings": { "title": "10-Week Build", "description": "Your sauna is handcrafted in our Vancouver WA workshop." } },
        { "type": "step", "settings": { "title": "Delivery & Installation", "description": "We deliver and set up your sauna at your property, ready to use." } },
        { "type": "step", "settings": { "title": "Enjoy Your Sauna", "description": "Step in and experience the warmth, quiet, and recovery." } }
      ]
    }
  ]
}
{% endschema %}
