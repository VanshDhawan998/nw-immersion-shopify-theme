<section class="nw-pdp-section nw-pdp-accordion-section" id="nw-product-accordion-{{ section.id }}">
  <div class="nw-pdp-accordion-inner">
    <div class="nw-pdp-accordion" role="list" aria-label="Product information">

      {%- for block in section.blocks -%}
        {%- if block.type == 'accordion_item' -%}
        <div class="nw-pdp-accordion__item nw-fade-up nw-fade-up--d{{ forloop.index | modulo: 5 | plus: 1 }}" role="listitem" {{ block.shopify_attributes }}>
          <button
            class="nw-pdp-accordion__trigger"
            type="button"
            aria-expanded="false"
            aria-controls="acc-content-{{ block.id }}"
            id="acc-trigger-{{ block.id }}"
          >
            <span class="nw-pdp-accordion__name">{{ block.settings.title }}</span>
            <span class="nw-pdp-accordion__icon" aria-hidden="true">
              <!-- Plus icon — rotates to × when open -->
              <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
                <line x1="7" y1="1" x2="7" y2="13"/>
                <line x1="1" y1="7" x2="13" y2="7"/>
              </svg>
            </span>
          </button>
          <div
            class="nw-pdp-accordion__content"
            id="acc-content-{{ block.id }}"
            role="region"
            aria-labelledby="acc-trigger-{{ block.id }}"
          >
            <div class="nw-pdp-accordion__body">
              {{ block.settings.content }}
            </div>
          </div>
        </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "NW Product Accordion",
  "tag": "div",
  "class": "nw-pdp-section-wrapper",
  "settings": [],
  "blocks": [
    {
      "type": "accordion_item",
      "name": "Accordion Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Section title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Accordion content goes here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NW Product Accordion",
      "blocks": [
        {
