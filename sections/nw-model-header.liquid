  "tag": "header",
  "class": "nw-model-header-section",
  "settings": [
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement Bar",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "Free Shipping on all saunas"
    },
    {
      "type": "color",
      "id": "announcement_bg",
      "label": "Announcement Background",
      "default": "#252220"
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "url",
      "id": "logo_image_url",
      "label": "Logo Image URL (fallback)"
    },
    {
      "type": "url",
      "id": "logo_link",
      "label": "Logo Link",
      "default": "/"
    },
    {
      "type": "header",
      "content": "Shop Button"
    },
    {
      "type": "text",
      "id": "shop_button_text",
      "label": "Shop Button Text",
      "default": "SHOP"
    },
    {
      "type": "url",
      "id": "shop_button_url",
      "label": "Shop Button URL"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Nav Link",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
