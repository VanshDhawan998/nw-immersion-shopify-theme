{% comment %}
  NW Hero — Full-height hero with background image, overlay, title & CTA
  Extracted from nw-landing-page.html design
  NOTE: Navigation is handled by nw-custom-header.liquid — this is hero content only
{% endcomment %}

{%- style -%}
  /* ========== HERO SECTION ========== */
  .nw-hero {
    position: relative;
    height: 780px;
    overflow: hidden;
    font-family: 'Raleway', sans-serif;
  }

  .nw-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .nw-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .nw-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 1;
  }

  .nw-hero__glow {
    position: absolute;
    top: -410px;
    left: -62px;
    width: 1543px;
    height: 820px;
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(255,255,255,0.08), transparent 70%);
    z-index: 2;
    pointer-events: none;
  }

  .nw-hero__content {
    position: absolute;
    z-index: 5;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    margin-top: -30px;
    width: 90%;
  }

  .nw-hero__title {
    font-size: 60px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    line-height: 1.15;
    margin-bottom: 50px;
  }

  .nw-hero__cta {
    display: inline-block;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    padding: 20px 40px;
    border-radius: 4px;
    font-size: 16px;
    font-weight: 700;
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }

  .nw-hero__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.25);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .nw-hero { height: 620px; }
    .nw-hero__title { font-size: 42px; }
    .nw-hero__cta { padding: 16px 32px; }
  }

  @media (max-width: 768px) {
    .nw-hero { height: 500px; }
    .nw-hero__title { font-size: 32px; margin-bottom: 30px; }
    .nw-hero__title br { display: none; }
    .nw-hero__cta { padding: 14px 28px; font-size: 14px; }
    .nw-hero__glow { display: none; }
  }

  @media (max-width: 480px) {
    .nw-hero { height: 420px; }
    .nw-hero__title { font-size: 26px; margin-bottom: 24px; }
    .nw-hero__cta { padding: 12px 24px; font-size: 13px; }
  }

  @media (max-width: 375px) {
    .nw-hero { height: 380px; }
    .nw-hero__title { font-size: 22px; margin-bottom: 20px; }
    .nw-hero__cta { padding: 10px 20px; font-size: 12px; }
  }
{%- endstyle -%}

<section class="nw-hero">
  <div class="nw-hero__bg">
    {%- if section.settings.background_image != blank -%}
      <img src="{{ section.settings.background_image | image_url: width: 1920 }}" alt="{{ section.settings.heading | strip_html }}" loading="eager" fetchpriority="high">
    {%- else -%}
      <img src="{{ section.settings.background_image_url }}" alt="{{ section.settings.heading | strip_html }}" loading="eager" fetchpriority="high">
    {%- endif -%}
  </div>
  <div class="nw-hero__overlay"></div>
  {%- if section.settings.show_glow -%}
    <div class="nw-hero__glow"></div>
  {%- endif -%}

  <div class="nw-hero__content">
    <h1 class="nw-hero__title">{{ section.settings.heading }}</h1>
    {%- if section.settings.button_text != blank -%}
      <a href="{{ section.settings.button_link }}" class="nw-hero__cta">{{ section.settings.button_text }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "NW Hero",
  "tag": "section",
  "class": "nw-hero-section",
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Step into a space built<br>for warmth, wellness & Calm</p>"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "background_image_url",
      "label": "Background image URL (fallback)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity (%)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "show_glow",
      "label": "Show glow effect",
      "default": true
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Saunas and Cold Plunges"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "NW Hero",
      "settings": {
        "heading": "<p>Step into a space built<br>for warmth, wellness & Calm</p>"
      }
    }
  ]
}
{% endschema %}
