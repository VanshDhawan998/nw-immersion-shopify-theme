{% comment %}
  NW Model Visit — Visit Our Warehouse CTA banner
{% endcomment %}

{%- style -%}
  /* ========== MODEL VISIT ========== */
  .nw-model-visit {
    position: relative;
    overflow: hidden;
    font-family: 'Raleway', sans-serif;
    min-height: 500px;
  }

  .nw-model-visit__bg {
    position: absolute;
    inset: 0;
    border-radius: 8px;
    overflow: hidden;
    margin: 0 100px;
  }

  .nw-model-visit__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .nw-model-visit__overlay {
    position: absolute;
    inset: 0;
    background: rgba(37, 34, 32, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    border-radius: 8px;
    margin: 0 100px;
    z-index: 1;
  }

  .nw-model-visit__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 100px;
    min-height: 500px;
    gap: 25px;
  }

  .nw-model-visit__title {
    font-family: 'Raleway', sans-serif;
    font-size: 40px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    line-height: 50px;
    margin: 0;
  }

  .nw-model-visit__desc {
    font-family: 'Raleway', sans-serif;
    font-size: 18px;
    color: {{ section.settings.text_color }};
    line-height: 28px;
    margin: 0;
    max-width: 700px;
  }

  .nw-model-visit__actions {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .nw-model-visit__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 30px;
    font-family: 'Raleway', sans-serif;
    font-size: 18px;
    font-weight: 700;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    height: 44px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .nw-model-visit__btn--primary {
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text }};
  }

  .nw-model-visit__btn--secondary {
    background: transparent;
    color: {{ section.settings.text_color }};
    border: 2px solid {{ section.settings.text_color }};
    padding: 8px 28px;
  }

  .nw-model-visit__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }

  .nw-model-visit__phone {
    font-family: 'Raleway', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .nw-model-visit__phone:hover {
    text-decoration: underline;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1200px) {
    .nw-model-visit__bg,
    .nw-model-visit__overlay { margin: 0 60px; }
    .nw-model-visit__content { padding: 100px 80px; }
  }

  @media (max-width: 1024px) {
    .nw-model-visit { min-height: auto; }
    .nw-model-visit__bg,
    .nw-model-visit__overlay { margin: 0 40px; border-radius: 20px; }
    .nw-model-visit__content { min-height: auto; padding: 80px 60px; }
    .nw-model-visit__title { font-size: 34px; line-height: 44px; }
  }

  @media (max-width: 768px) {
    .nw-model-visit__bg,
    .nw-model-visit__overlay { margin: 0 20px; border-radius: 8px; }
    .nw-model-visit__content { padding: 60px 30px; }
    .nw-model-visit__title { font-size: 28px; line-height: 38px; }
    .nw-model-visit__actions { flex-direction: column; }
  }

  @media (max-width: 480px) {
    .nw-model-visit__bg,
    .nw-model-visit__overlay { margin: 0 16px; border-radius: 12px; }
    .nw-model-visit__content { padding: 40px 20px; }
    .nw-model-visit__title { font-size: 24px; line-height: 34px; }
    .nw-model-visit__desc { font-size: 16px; line-height: 26px; }
  }
{%- endstyle -%}

<section class="nw-model-visit">
  <div class="nw-model-visit__bg">
    {%- if section.settings.background_image != blank -%}
      <img src="{{ section.settings.background_image | image_url: width: 1920 }}" alt="{{ section.settings.heading }}" loading="lazy">
    {%- elsif section.settings.background_image_url != blank -%}
      <img src="{{ section.settings.background_image_url }}" alt="{{ section.settings.heading }}" loading="lazy">
    {%- endif -%}
  </div>
  <div class="nw-model-visit__overlay"></div>

  <div class="nw-model-visit__content">
    <h2 class="nw-model-visit__title">{{ section.settings.heading }}</h2>
    {%- if section.settings.description != blank -%}
      <p class="nw-model-visit__desc">{{ section.settings.description }}</p>
    {%- endif -%}

    <div class="nw-model-visit__actions">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="nw-model-visit__btn nw-model-visit__btn--primary">{{ section.settings.button_label }}</a>
      {%- endif -%}
      {%- if section.settings.secondary_button_label != blank -%}
        <a href="{{ section.settings.secondary_button_link }}" class="nw-model-visit__btn nw-model-visit__btn--secondary">{{ section.settings.secondary_button_label }}</a>
      {%- endif -%}
      {%- if section.settings.phone_number != blank -%}
        <a href="tel:{{ section.settings.phone_number | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}" class="nw-model-visit__phone">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {{ section.settings.phone_number }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NW Model Visit",
  "tag": "section",
  "class": "nw-model-visit-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Visit Our Vancouver WA Warehouse"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "See our saunas in person. Walk through a finished model, feel the cedar, and talk to the team that builds them."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "url",
      "id": "background_image_url",
      "label": "Background Image URL (fallback)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FCFCFC"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary Button Text",
      "default": "Schedule a Visit"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Primary Button BG",
      "default": "#546659"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Primary Button Text Color",
      "default": "#FCFCFC"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary Button Text"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "(360) 907-8928"
    }
  ],
  "presets": [
    {
      "name": "NW Model Visit"
    }
  ]
}
{% endschema %}
