      "min": 24,
      "max": 48,
      "step": 2,
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_weight",
      "label": "Main Heading Weight",
      "min": 400,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "range",
      "id": "question_font_size",
      "label": "Question Font Size (px)",
      "min": 14,
      "max": 24,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "question_font_weight",
      "label": "Question Font Weight",
      "min": 400,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "range",
      "id": "answer_font_size",
      "label": "Answer Font Size (px)",
      "min": 14,
      "max": 24,
      "step": 1,
      "default": 18
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background Color",
      "default": "#FCF9F4"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Main Heading Color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "General Text Color",
      "default": "#252220"
    },
    {
      "type": "color",
      "id": "question_background_color",
      "label": "Question Background Color",
      "default": "#fbefdb"
    },
    {
      "type": "color",
      "id": "question_text_color",
      "label": "Question Text Color",
      "default": "#252220"
    },
    {
      "type": "color",
      "id": "answer_background_color",
      "label": "Answer Background Color",
      "default": "#fbefdb"
    },
    {
      "type": "color",
      "id": "answer_text_color",
      "label": "Answer Text Color",
      "default": "#252220"
    },
    {
      "type": "color",
      "id": "item_border_color",
      "label": "FAQ Item Border Color",
      "default": "#e5e5e5"
    },
    {
      "type": "color",
      "id": "icon_background_color",
      "label": "Icon Background Color",
      "default": "#546659"
    },
    {
      "type": "color",
      "id": "icon_text_color",
      "label": "Icon Text Color",
      "default": "#ffffff"
