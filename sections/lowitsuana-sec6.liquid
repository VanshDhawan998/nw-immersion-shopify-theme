    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Button Font Size",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Button Border Radius",
      "default": 25
    },
    {
      "type": "range",
      "id": "button_margin_top",
      "min": 20,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Button Top Margin",
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step Card",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "step_label",
          "label": "Step Label",
          "default": "STEP"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description",
          "default": "Step description text goes here."
        },
        {
          "type": "checkbox",
          "id": "is_tall_card",
          "label": "Make this a tall card (spanning 2 rows)",
          "default": false,
          "info": "Check this for the final step card with logo and button"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo (for tall card only)",
          "info": "Only displays if 'Make this a tall card' is checked"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text (for tall card only)",
          "info": "Only displays if 'Make this a tall card' is checked"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link (for tall card only)",
          "info": "Only displays if 'Make this a tall card' is checked"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Journey Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_number": "01",
            "title": "Choose Your Loowit Online",
            "description": "Select the Loowit model and upgrades you'd like. Everything is ready to order online, so your sauna journey can start right away."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "02",
            "title": "Decide On Your Package Options",
            "description": "Want a little extra help? We offer virtual and in-person consultations to walk through the options and ensure you're confident about your choice."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "03",
            "title": "Secure Your Build With A Deposit",
            "description": "A 25% deposit locks in your place on our build calendar. From here, your sauna begins to move into production."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "04",
