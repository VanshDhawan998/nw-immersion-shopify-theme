          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "05",
            "title": "Delivery Day, Your Sauna Arrives",
            "description": "The best part! Once your build is complete and final payment is made, we coordinate delivery and installation support. Soon after, you'll be stepping inside your own Loowit sauna.",
            "is_tall_card": true,
            "button_text": "ORDER MY LOOWIT SAUNA",
            "button_link": "#"
          }
        }
      ]
    }
  ]
}
{% endschema %}