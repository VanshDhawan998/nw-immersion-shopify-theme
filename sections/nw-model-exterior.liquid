{% comment %}
  NW Model Exterior — Full-width bg image overlay with text + feature cards
  Used for "Sauna Accessories and Bespoke Upgrades" (Silver Star) and
  "Loowit Sauna Exterior: Strong Lines, Lasting Strength" sections.
{% endcomment %}

{%- style -%}
  /* ========== MODEL EXTERIOR ========== */
  .nw-model-exterior {
    position: relative;
    min-height: 834px;
    overflow: hidden;
    font-family: 'Articulat CF', 'Raleway', sans-serif;
  }

  .nw-model-exterior__bg {
    position: absolute;
    inset: 0;
    border-radius: 30px;
    overflow: hidden;
    margin: 0 100px;
  }

  .nw-model-exterior__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .nw-model-exterior__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    border-radius: 30px;
    margin: 0 100px;
    z-index: 1;
  }

  .nw-model-exterior__content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 50px;
    padding: 120px 150px;
    min-height: 834px;
  }

  .nw-model-exterior__text-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 30px;
    padding: 0 50px;
  }

  .nw-model-exterior__title {
    font-family: 'Articulat CF', sans-serif;
    font-size: 40px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    line-height: 50px;
    margin: 0;
  }

  .nw-model-exterior__desc {
    font-family: 'Quando', serif;
    font-size: 18px;
    color: {{ section.settings.text_color }};
    line-height: 28px;
    margin: 0;
  }

  .nw-model-exterior__cards-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 50px;
  }

  .nw-model-exterior__card {
    background: {{ section.settings.card_bg }};
    border-radius: 15px;
    padding: 50px;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .nw-model-exterior__card-title {
    font-family: 'Articulat CF', sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: {{ section.settings.card_text_color }};
    line-height: normal;
    margin: 0;
  }

  .nw-model-exterior__card-text {
    font-family: 'Quando', serif;
    font-size: 18px;
    color: {{ section.settings.card_text_color }};
    line-height: 28px;
    margin: 0;
  }

  .nw-model-exterior__card-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 30px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    font-family: 'Articulat CF', sans-serif;
    font-size: 18px;
    font-weight: 700;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    align-self: flex-start;
    height: 44px;
  }

  .nw-model-exterior__card-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1200px) {
    .nw-model-exterior__bg,
    .nw-model-exterior__overlay { margin: 0 60px; }
    .nw-model-exterior__content { padding: 100px 110px; }
  }

  @media (max-width: 1024px) {
    .nw-model-exterior { min-height: auto; }
    .nw-model-exterior__bg,
    .nw-model-exterior__overlay { margin: 0 40px; border-radius: 20px; }
    .nw-model-exterior__content {
      flex-direction: column;
      padding: 80px 80px;
      min-height: auto;
    }
    .nw-model-exterior__text-col { padding: 0; }
    .nw-model-exterior__title { font-size: 34px; line-height: 44px; }
  }

  @media (max-width: 768px) {
    .nw-model-exterior__bg,
    .nw-model-exterior__overlay { margin: 0 20px; border-radius: 15px; }
    .nw-model-exterior__content { padding: 60px 40px; gap: 30px; }
    .nw-model-exterior__title { font-size: 28px; line-height: 38px; }
    .nw-model-exterior__card { padding: 30px; gap: 20px; }
    .nw-model-exterior__card-title { font-size: 20px; }
  }

  @media (max-width: 480px) {
    .nw-model-exterior__bg,
    .nw-model-exterior__overlay { margin: 0 16px; border-radius: 12px; }
    .nw-model-exterior__content { padding: 40px 28px; }
    .nw-model-exterior__title { font-size: 24px; line-height: 34px; }
    .nw-model-exterior__desc { font-size: 16px; line-height: 26px; }
    .nw-model-exterior__card-text { font-size: 16px; line-height: 26px; }
  }
{%- endstyle -%}

<section class="nw-model-exterior">
  <div class="nw-model-exterior__bg">
    {%- if section.settings.background_image != blank -%}
      <img src="{{ section.settings.background_image | image_url: width: 1920 }}" alt="{{ section.settings.heading }}" loading="lazy">
    {%- elsif section.settings.background_image_url != blank -%}
      <img src="{{ section.settings.background_image_url }}" alt="{{ section.settings.heading }}" loading="lazy">
    {%- endif -%}
  </div>
  <div class="nw-model-exterior__overlay"></div>

  <div class="nw-model-exterior__content">
    <div class="nw-model-exterior__text-col">
      <h2 class="nw-model-exterior__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.description != blank -%}
        <p class="nw-model-exterior__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <div class="nw-model-exterior__cards-col">
      {%- for block in section.blocks -%}
        {%- if block.type == 'card' -%}
          <div class="nw-model-exterior__card" {{ block.shopify_attributes }}>
            <h3 class="nw-model-exterior__card-title">{{ block.settings.title }}</h3>
            <p class="nw-model-exterior__card-text">{{ block.settings.description }}</p>
            {%- if block.settings.button_text != blank -%}
              <a href="{{ block.settings.button_link }}" class="nw-model-exterior__card-btn">{{ block.settings.button_text }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NW Model Exterior",
  "tag": "section",
  "class": "nw-model-exterior-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Loowit Sauna Exterior: Strong Lines, Lasting Strength"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "url",
      "id": "background_image_url",
      "label": "Background Image URL (fallback)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 55,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FCFCFC"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#fbefdb"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text Color",
      "default": "#252220"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#546659"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#FCFCFC"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Feature Card",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Durability Meets Design"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Card Description",
          "default": "A standing seam metal roof and pressure-treated foundation give the sauna its backbone."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NW Model Exterior",
      "blocks": [
        { "type": "card", "settings": { "title": "Durability Meets Design", "description": "A standing seam metal roof and pressure-treated foundation give the sauna its backbone." } },
        { "type": "card", "settings": { "title": "Signature Exterior Features", "description": "A wide front window and glass door invite natural light while keeping the structure private." } }
      ]
    }
  ]
}
{% endschema %}
