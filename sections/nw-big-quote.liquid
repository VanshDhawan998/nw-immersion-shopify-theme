{% comment %}
  NW Big Quote — Full-width featured testimonial with decorative quotes + stars
  Extracted from nw-landing-page.html design
{% endcomment %}

{%- style -%}
  /* ========== BIG QUOTE ========== */
  .nw-big-quote {
    max-width: 1200px;
    margin: 30px auto 60px;
    border-radius: 12px;
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
    padding: 44px 72px;
    position: relative;
    min-height: 250px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: 'Raleway', sans-serif;
    background: #fff;
  }

  .nw-big-quote__open {
    position: absolute;
    left: -50px;
    top: -40px;
    font-size: 240px;
    font-weight: 700;
    color: #000;
    opacity: 0.1;
    line-height: 1;
    pointer-events: none;
  }

  .nw-big-quote__close {
    position: absolute;
    right: 60px;
    top: -20px;
    font-size: 240px;
    font-weight: 700;
    color: #000;
    opacity: 0.1;
    line-height: 1;
    pointer-events: none;
    transform: rotate(180deg);
  }

  .nw-big-quote__left {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 720px;
  }

  .nw-big-quote__text {
    font-size: 40px;
    font-weight: 700;
    color: #000;
    line-height: 1.25;
    position: relative;
  }

  .nw-big-quote__author {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nw-big-quote__author img {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    object-fit: cover;
  }

  .nw-big-quote__author span {
    font-size: 24px;
    font-weight: 600;
    color: #000;
  }

  .nw-big-quote__stars {
    display: flex;
    gap: 5px;
    align-self: center;
  }

  .nw-big-quote__stars svg {
    width: 40px;
    height: 40px;
    fill: {{ section.settings.star_color }};
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .nw-big-quote { padding: 36px 48px; margin-left: 30px; margin-right: 30px; }
    .nw-big-quote__text { font-size: 28px; }
    .nw-big-quote__open { font-size: 160px; left: -30px; top: -30px; }
    .nw-big-quote__close { font-size: 160px; right: 30px; top: -10px; }
  }

  @media (max-width: 768px) {
    .nw-big-quote {
      flex-direction: column;
      gap: 24px;
      padding: 32px 28px;
      margin: 20px 20px;
      text-align: center;
    }
    .nw-big-quote__left { align-items: center; }
    .nw-big-quote__text { font-size: 24px; }
    .nw-big-quote__author span { font-size: 18px; }
    .nw-big-quote__open { font-size: 120px; left: -10px; top: -20px; }
    .nw-big-quote__close { font-size: 120px; right: 10px; top: -10px; }
    .nw-big-quote__stars svg { width: 28px; height: 28px; }
  }

  @media (max-width: 480px) {
    .nw-big-quote { padding: 24px 20px; }
    .nw-big-quote__text { font-size: 20px; }
    .nw-big-quote__author img { width: 44px; height: 44px; }
    .nw-big-quote__author span { font-size: 16px; }
    .nw-big-quote__open, .nw-big-quote__close { font-size: 80px; }
    .nw-big-quote__stars svg { width: 24px; height: 24px; }
  }

  @media (max-width: 375px) {
    .nw-big-quote__text { font-size: 18px; }
  }
{%- endstyle -%}

<div class="nw-big-quote">
  <span class="nw-big-quote__open">&ldquo;</span>
  <span class="nw-big-quote__close">&rdquo;</span>
  <div class="nw-big-quote__left">
    <blockquote class="nw-big-quote__text">{{ section.settings.quote }}</blockquote>
    <div class="nw-big-quote__author">
      {%- if section.settings.author_image != blank -%}
        <img src="{{ section.settings.author_image | image_url: width: 120 }}" alt="{{ section.settings.author_name }}" loading="lazy">
      {%- elsif section.settings.author_image_url != blank -%}
        <img src="{{ section.settings.author_image_url }}" alt="{{ section.settings.author_name }}" loading="lazy">
      {%- endif -%}
      <span>{{ section.settings.author_name }}</span>
    </div>
  </div>
  <div class="nw-big-quote__stars">
    {%- assign stars = section.settings.star_count | default: 5 -%}
    {%- for i in (1..stars) -%}
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "NW Big Quote",
  "tag": "section",
  "class": "nw-big-quote-section",
  "settings": [
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote text",
      "default": "A total game changer. I use it daily — it keeps me feeling decades younger"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author name",
      "default": "Larry S"
    },
    {
      "type": "image_picker",
      "id": "author_image",
      "label": "Author avatar"
    },
    {
      "type": "text",
      "id": "author_image_url",
      "label": "Author avatar URL (fallback)"
    },
    {
      "type": "range",
      "id": "star_count",
      "label": "Star count",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "NW Big Quote",
      "settings": {
        "quote": "A total game changer. I use it daily — it keeps me feeling decades younger",
        "author_name": "Larry S",
        "author_image_url": "https://www.figma.com/api/mcp/asset/cc3e9b04-3304-4f37-8eaa-e68cdf42046a"
      }
    }
  ]
}
{% endschema %}
