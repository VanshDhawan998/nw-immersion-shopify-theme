<!-- Shopify Showroom Section -->
<div class="showroom-section showroom-section-{{ section.id }}">
  <div class="contact-section" 
       {% if section.settings.background_image %}
         style="background-image: linear-gradient(to right, rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }}) 0%, rgba(0, 0, 0, {{ section.settings.overlay_opacity | plus: 25 | divided_by: 100.0 }}) 70%, rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }}) 100%), url({{ section.settings.background_image | image_url: width: 1920 }});"
       {% else %}
         style="background: {{ section.settings.background_color }};"
       {% endif %}>
    
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="contact-content">
      <div class="timing-text">
        {% comment %} Store Hours {% endcomment %}
        {% if section.settings.thursday_friday_saturday != blank %}
          <span>{{ section.settings.thursday_friday_saturday }}</span>
        {% endif %}

        {% if section.settings.sunday_hours != blank %}
          <span>{{ section.settings.sunday_hours }}</span>
        {% endif %}

        {% if section.settings.monday_wednesday != blank %}
          <span>{{ section.settings.monday_wednesday }}</span>
        {% endif %}

        {% comment %} Address {% endcomment %}
        {% if section.settings.address != blank %}
          <span>{{ section.settings.address }}</span>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
  .showroom-section-{{ section.id }} {
    width: 100%;
    margin: {{ section.settings.section_margin_top | default: 0 }}px {{ section.settings.section_margin_right | default: 0 }}px {{ section.settings.section_margin_bottom | default: 0 }}px {{ section.settings.section_margin_left | default: 0 }}px;
    padding: {{ section.settings.section_padding_top | default: 130 }}px {{ section.settings.section_padding_right | default: 50 }}px {{ section.settings.section_padding_bottom | default: 0 }}px {{ section.settings.section_padding_left | default: 50 }}px;
  }

  .showroom-section-{{ section.id }} .contact-section {
    width: 100%;
    max-width: 1670px;
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: {{ section.settings.section_padding_top }}px {{ section.settings.section_padding_right }}px {{ section.settings.section_padding_bottom }}px {{ section.settings.section_padding_left }}px;
    margin: {{ section.settings.section_margin_top }}px auto {{ section.settings.section_margin_bottom }}px auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    color: {{ section.settings.text_color }};
  }

  .showroom-section-{{ section.id }} h2 {
    font-family: {{ section.settings.heading_font }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: {{ section.settings.heading_line_height }}px;
    margin-bottom: 30px;
    color: {{ section.settings.heading_color }};
  }

  .showroom-section-{{ section.id }} .contact-content {
    width: {{ section.settings.content_width }}%;
    padding: {{ section.settings.content_padding_top }}px {{ section.settings.content_padding_right }}px {{ section.settings.content_padding_bottom }}px {{ section.settings.content_padding_left }}px;
    margin: {{ section.settings.content_margin_top }}px {{ section.settings.content_margin_right }}px {{ section.settings.content_margin_bottom }}px {{ section.settings.content_margin_left }}px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .showroom-section-{{ section.id }} .timing-text {
    width: 100%;
  }

  .showroom-section-{{ section.id }} .timing-text span {
    padding-left: {{ section.settings.text_indent }}px;
    display: block;
    font-family: {{ section.settings.body_font }};
    font-size: {{ section.settings.text_size }}px;
    font-weight: {{ section.settings.text_weight }};
    line-height: {{ section.settings.text_line_height }}px;
    margin: {{ section.settings.text_margin }}px 0;
    color: {{ section.settings.text_color }};
  }

  .showroom-section-{{ section.id }} .timing-text span:last-child {
    margin-top: {{ section.settings.address_margin_top }}px;
  }

  /* Responsive Design */
  @media (max-width: 1670px) {
    .showroom-section-{{ section.id }} .contact-section {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 992px) {
    .showroom-section-{{ section.id }} .contact-section {
      flex-direction: column;
      align-items: flex-start;
      padding: {{ section.settings.section_padding_top | times: 0.67 }}px {{ section.settings.section_padding_right | times: 0.5 }}px {{ section.settings.section_padding_bottom | times: 0.67 }}px {{ section.settings.section_padding_left | times: 0.5 }}px;
      margin: {{ section.settings.section_margin_top | times: 0.67 }}px auto {{ section.settings.section_margin_bottom | times: 0.67 }}px auto;
    }

    .showroom-section-{{ section.id }} .contact-content {
      width: 100%;
      padding: {{ section.settings.content_padding_top | times: 0.67 }}px {{ section.settings.content_padding_right | times: 0.5 }}px {{ section.settings.content_padding_bottom | times: 0.67 }}px {{ section.settings.content_padding_left | times: 0.5 }}px;
      margin: {{ section.settings.content_margin_top | times: 0.67 }}px {{ section.settings.content_margin_right | times: 0.5 }}px {{ section.settings.content_margin_bottom | times: 0.67 }}px {{ section.settings.content_margin_left | times: 0.5 }}px;
    }
  }

  @media (max-width: 768px) {
    .showroom-section-{{ section.id }} {
      padding: {{ section.settings.section_padding_top | times: 0.7 }}px {{ section.settings.section_padding_right | times: 0.6 }}px 0 {{ section.settings.section_padding_left | times: 0.6 }}px;
    }

    .showroom-section-{{ section.id }} .contact-section {
      padding: {{ section.settings.section_padding_top | times: 0.5 }}px {{ section.settings.section_padding_right | times: 0.3 }}px {{ section.settings.section_padding_bottom | times: 0.5 }}px {{ section.settings.section_padding_left | times: 0.3 }}px;
      margin: {{ section.settings.section_margin_top | times: 0.5 }}px auto {{ section.settings.section_margin_bottom | times: 0.5 }}px auto;
    }
  }

  @media (max-width: 576px) {
    .showroom-section-{{ section.id }} h2 {
      font-size: {{ section.settings.heading_size | times: 0.8 }}px;
    }

    .showroom-section-{{ section.id }} .timing-text span {
      font-size: {{ section.settings.text_size | times: 0.9 }}px;
      padding-left: {{ section.settings.text_indent | times: 0.5 }}px;
    }

    .showroom-section-{{ section.id }} .contact-section {
      padding: {{ section.settings.section_padding_top | times: 0.33 }}px {{ section.settings.section_padding_right | times: 0.2 }}px {{ section.settings.section_padding_bottom | times: 0.33 }}px {{ section.settings.section_padding_left | times: 0.2 }}px;
      margin: {{ section.settings.section_margin_top | times: 0.33 }}px auto {{ section.settings.section_margin_bottom | times: 0.33 }}px auto;
    }

    .showroom-section-{{ section.id }} .contact-content {
      padding: {{ section.settings.content_padding_top | times: 0.33 }}px {{ section.settings.content_padding_right | times: 0.2 }}px {{ section.settings.content_padding_bottom | times: 0.33 }}px {{ section.settings.content_padding_left | times: 0.2 }}px;
      margin: {{ section.settings.content_margin_top | times: 0.33 }}px {{ section.settings.content_margin_right | times: 0.2 }}px {{ section.settings.content_margin_bottom | times: 0.33 }}px {{ section.settings.content_margin_left | times: 0.2 }}px;
    }
  }

  @media (max-width: 480px) {
    .showroom-section-{{ section.id }} h2 {
      font-size: {{ section.settings.heading_size | times: 0.65 }}px;
      text-align: {{ section.settings.mobile_heading_alignment }};
    }

    .showroom-section-{{ section.id }} .timing-text {
      text-align: {{ section.settings.mobile_text_alignment }};
    }

    .showroom-section-{{ section.id }} .timing-text span {
      padding-left: 0;
      font-size: {{ section.settings.text_size | times: 0.85 }}px;
    }

    .showroom-section-{{ section.id }} .contact-content {
      padding: {{ section.settings.content_padding_top | times: 0.25 }}px {{ section.settings.content_padding_right | times: 0.1 }}px {{ section.settings.content_padding_bottom | times: 0.25 }}px {{ section.settings.content_padding_left | times: 0.1 }}px;
      margin: {{ section.settings.content_margin_top | times: 0.25 }}px {{ section.settings.content_margin_right | times: 0.1 }}px {{ section.settings.content_margin_bottom | times: 0.25 }}px {{ section.settings.content_margin_left | times: 0.1 }}px;
    }
  }

  /* Google Fonts Import */
  @import url('https://fonts.googleapis.com/css2?family=Quando&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap');
</style>

{% schema %}
{
  "name": "Showroom Section",
  "tag": "section",
  "class": "showroom-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Come Visit Our Showroom in Vancouver, WA"
    },
    {
      "type": "text",
      "id": "thursday_friday_saturday",
      "label": "Thursday - Saturday Hours",
      "default": "Thurs – Sat: 10 AM – 6 PM"
    },
    {
      "type": "text",
      "id": "sunday_hours",
      "label": "Sunday Hours",
      "default": "Sun: 11 AM- 5 PM"
    },
    {
      "type": "text",
      "id": "monday_wednesday",
      "label": "Monday - Wednesday Hours",
      "default": "Mon-Wed: By Appointment – call/text: 360-360-6968 to schedule"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Store Address",
      "default": "5305 NE 121st Ave, Ste 216<br/>Vancouver, WA 98682"
    },
    {
      "type": "header",
      "content": "Background & Visual Settings"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fallback Background Color",
      "default": "#252220",
      "info": "Used when no background image is selected"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 22,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Typography Settings"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "sans-serif",
      "options": [
        { "value": "sans-serif", "label": "Sans Serif" },
        { "value": "serif", "label": "Serif" },
        { "value": "\"Quando\", serif", "label": "Quando" },
        { "value": "\"Roboto\", sans-serif", "label": "Roboto" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 24,
      "max": 80,
      "step": 2,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_weight",
      "label": "Heading Font Weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "label": "Heading Line Height",
      "min": 30,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "body_font",
      "label": "Body Text Font",
      "default": "\"Roboto\", sans-serif",
      "options": [
        { "value": "sans-serif", "label": "Sans Serif" },
        { "value": "serif", "label": "Serif" },
        { "value": "\"Quando\", serif", "label": "Quando" },
        { "value": "\"Roboto\", sans-serif", "label": "Roboto" }
      ]
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Body Text Size",
      "min": 12,
      "max": 32,
      "step": 1,
      "default": 18,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "text_weight",
      "label": "Body Text Weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 400
    },
    {
      "type": "range",
      "id": "text_line_height",
      "label": "Body Text Line Height",
      "min": 20,
      "max": 50,
      "step": 1,
      "default": 29,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "header",
      "content": "Section Margin Settings"
    },
    {
      "type": "range",
      "id": "section_margin_top",
      "label": "Section Top Margin",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_margin_right",
      "label": "Section Right Margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_margin_bottom",
      "label": "Section Bottom Margin",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_margin_left",
      "label": "Section Left Margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Section Padding Settings"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section Top Padding",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 130,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_right",
      "label": "Section Right Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section Bottom Padding",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_left",
      "label": "Section Left Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content Width",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 70,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Content Margin Settings"
    },
    {
      "type": "range",
      "id": "content_margin_top",
      "label": "Content Top Margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "content_margin_right",
      "label": "Content Right Margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "content_margin_bottom",
      "label": "Content Bottom Margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "content_margin_left",
      "label": "Content Left Margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Content Padding Settings"
    },
    {
      "type": "range",
      "id": "content_padding_top",
      "label": "Content Top Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "content_padding_right",
      "label": "Content Right Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "content_padding_bottom",
      "label": "Content Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "content_padding_left",
      "label": "Content Left Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "text_indent",
      "label": "Text Indent",
      "min": 0,
      "max": 60,
      "step": 5,
      "default": 30,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "text_margin",
      "label": "Text Margin",
      "min": 5,
      "max": 39,
      "step": 2,
      "default": 17,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "address_margin_top",
      "label": "Address Top Margin",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Mobile Settings"
    },
    {
      "type": "select",
      "id": "mobile_heading_alignment",
      "label": "Mobile Heading Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "mobile_text_alignment",
      "label": "Mobile Text Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Showroom Section"
    }
  ]
}
{% endschema %}