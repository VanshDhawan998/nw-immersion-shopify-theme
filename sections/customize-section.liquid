<style>
  /* Google Fonts Import */
  @import url('https://fonts.googleapis.com/css2?family=Quando&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap');

  /* CSS Variables */
  :root {
    --font-heading: sans-serif;
    --font-body: "Quando", serif;
    --font-button: "Roboto", sans-serif;
    --color-dark: rgb(37, 34, 32);
    --color-accent: #546659;
    --section-heading-size: 40px;
    --section-heading-weight: 700;
    --section-heading-line: 50px;
    --section-text-size: 18px;
    --section-text-weight: 400;
    --section-text-line: 28px;
    --btn-medium-size: 18px;
    --btn-medium-padding: 10px 30px;
    --btn-medium-line: 22px;
    --mb: 30px;
    --py: 130px;
    --px: 50px;
  }

  /* Section Styling */
  .customize-section {
    width: 100%;
    padding: {{ section.settings.section_padding_top | default: 130 }}px var(--px) {{ section.settings.section_padding_bottom | default: 0 }}px;
  }

  .contact-section {
    width: 100%;
    border-radius: 22px;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 120px 100px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    color: white;
  }

  .contact-section h2 {
    font-family: var(--font-heading);
    font-size: var(--section-heading-size);
    font-weight: var(--section-heading-weight);
    line-height: var(--section-heading-line);
    margin-bottom: var(--mb);
    color: white;
  }

  .contact-section p {
    font-family: var(--font-button);
    font-weight: var(--section-text-weight);
    font-size: 16px;
    max-width: 80%;
    color: white;
  }

  .contact-content {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  .contact-text {
    display: flex;
    gap: 60px;
    flex-wrap: wrap;
    align-items: center;
  }

  .button-wrapper {
    display: flex;
    align-items: center;
  }

  .contact-item {
    flex: 1 1 auto;
    min-width: 200px;
    display: flex;
    align-items: center;
    gap: 15px;
    font-size: var(--section-text-size);
    font-weight: var(--section-text-weight);
    line-height: var(--section-text-line);
    text-decoration: none;
    color: white;
    transition: 0.3s ease;
  }

  .contact-item:hover {
    opacity: 0.8;
  }

  .contact-icon {
    width: 38px;
    height: 38px;
    background: {{ section.settings.accent_color | default: '#546659' }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .custom-btn {
    width: fit-content;
    background: {{ section.settings.accent_color | default: '#546659' }};
    color: white;
    border-radius: 50px;
    text-decoration: none;
    font-family: var(--font-button);
    font-weight: 700;
    font-size: var(--btn-medium-size);
    padding: var(--btn-medium-padding);
    line-height: var(--btn-medium-line);
    transition: 0.3s ease;
    display: inline-block;
    border: 1px solid {{ section.settings.accent_color | default: '#546659' }};
  }

  .custom-btn:hover {
    background: #ffffff;
    color: {{ section.settings.accent_color | default: '#546659' }};
  }

  /* Responsive Design */
  @media (max-width: 1670px) {
    .contact-section {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 992px) {
    .contact-section {
      flex-direction: column;
      align-items: flex-start;
      padding: 80px 50px;
    }

    .contact-content {
      width: 100%;
      flex-direction: column;
      align-items: flex-start;
      gap: 30px;
    }

    .contact-text {
      width: 100%;
      flex-direction: column;
      gap: 20px;
      align-items: flex-start;
    }

    .contact-item,
    .button-wrapper {
      min-width: unset;
    }
  }

  @media (max-width: 768px) {
    .customize-section {
      padding: calc(var(--py) * 0.7) calc(var(--px) * 0.6) 0;
    }

    .contact-section {
      padding: 60px 30px;
    }

    .contact-section h2 {
      font-size: calc(var(--section-heading-size) * 0.8);
    }

    .contact-section p {
      max-width: 100%;
    }
  }

  @media (max-width: 576px) {
    .contact-section {
      padding: 40px 20px;
    }

    .contact-section h2 {
      font-size: calc(var(--section-heading-size) * 0.7);
      text-align: center;
    }

    .contact-section p {
      text-align: center;
      font-size: 14px;
    }

    .contact-text {
      align-items: center;
      text-align: center;
    }

    .contact-item {
      justify-content: center;
    }

    .button-wrapper {
      justify-content: center;
      width: 100%;
    }

    .custom-btn {
      width: 100%;
      text-align: center;
      padding: 12px 20px;
    }
  }

  @media (max-width: 480px) {
    .contact-section h2 {
      font-size: calc(var(--section-heading-size) * 0.6);
    }

    .contact-icon {
      width: 32px;
      height: 32px;
    }

    .contact-icon svg {
      width: 16px;
      height: 16px;
    }
  }
</style>

<div class="customize-section">
  <div class="contact-section" style="background-image: linear-gradient(to right, rgba(0, 0, 0, 0.2) 0%, rgba(0, 0, 0, 0.45) 70%, rgba(0, 0, 0, 0.3) 100%), url('{{ section.settings.background_image | image_url }}');">
    <h2>{{ section.settings.section_title | default: "Customize Your Silver Star Sauna" }}</h2>
    <p>{{ section.settings.section_description }}</p>

    <div class="contact-content">
      <div class="contact-text">
        {% if section.settings.phone_number != blank %}
        <a href="tel:{{ section.settings.phone_number | replace: ' ', '' | replace: '(', '' | replace: ')', '' | replace: '-', '' }}" class="contact-item">
          <div class="contact-icon">
            <!-- Phone SVG Icon -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
              <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.11.37 2.3.57 3.58.57a1 1 0 011 1v3.5a1 1 0 01-1 1C10.07 22 2 13.93 2 3.5a1 1 0 011-1H6.5a1 1 0 011 1c0 1.28.2 2.47.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z"/>
            </svg>
          </div>
          <span>{{ section.settings.phone_number }}</span>
        </a>
        {% endif %}

        {% if section.settings.email_address != blank %}
        <a href="mailto:{{ section.settings.email_address }}" class="contact-item">
          <div class="contact-icon">
            <!-- Mail SVG Icon -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
              <path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </div>
          <span>{{ section.settings.email_address }}</span>
        </a>
        {% endif %}

        {% if section.settings.button_text != blank %}
        <div class="button-wrapper">
          <a href="{{ section.settings.button_link | default: '#' }}" class="custom-btn medium">
            {{ section.settings.button_text }}
          </a>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customize Section",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Recommended size: 1920x600px"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Customize Your Silver Star Sauna"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "label": "Description",
      "default": "Whether you already have a vision in mind or you're just beginning to explore, we're here to help shape the project. Contact us to discuss your ideas, request pricing, or plan a consultation."
    },
    {
      "type": "header",
      "content": "Contact Information"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "(360) 360-6968"
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Email Address",
      "default": "info@nwimmersion.com"
    },
    {
      "type": "header",
      "content": "Call-to-Action Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Send Me My Silver Star Quote"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#546659"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "label": "Section Padding Top",
      "default": 130
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "label": "Section Padding Bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Customize Section"
    }
  ]
}
{% endschema %}