{% comment %}
  NW Model Accessories — Bespoke upgrades section with checklist + bg image
  Used for "Sauna Accessories and Bespoke Upgrades" on Silver Star page.
{% endcomment %}

{%- style -%}
  /* ========== MODEL ACCESSORIES ========== */
  .nw-model-accessories {
    position: relative;
    min-height: 834px;
    overflow: hidden;
    font-family: 'Articulat CF', 'Raleway', sans-serif;
  }

  .nw-model-accessories__bg {
    position: absolute;
    inset: 0;
    border-radius: 30px;
    overflow: hidden;
    margin: 0 100px;
  }

  .nw-model-accessories__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .nw-model-accessories__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(37, 34, 32, {{ section.settings.overlay_opacity | divided_by: 100.0 }}) 0%, rgba(37, 34, 32, 0) 100%);
    border-radius: 30px;
    margin: 0 100px;
    z-index: 1;
  }

  .nw-model-accessories__content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: flex-start;
    gap: 60px;
    padding: 120px 150px;
    min-height: 834px;
  }

  .nw-model-accessories__text-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 30px;
    max-width: 600px;
  }

  .nw-model-accessories__title {
    font-family: 'Articulat CF', sans-serif;
    font-size: 40px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    line-height: 50px;
    margin: 0;
  }

  .nw-model-accessories__desc {
    font-family: 'Quando', serif;
    font-size: 18px;
    color: {{ section.settings.text_color }};
    line-height: 28px;
    margin: 0;
  }

  .nw-model-accessories__checklist {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 10px;
  }

  .nw-model-accessories__check-item {
    display: flex;
    align-items: center;
    gap: 17px;
    padding: 15px 0;
    border-bottom: 1px solid rgba(252, 252, 252, 0.2);
  }

  .nw-model-accessories__check-item:last-child {
    border-bottom: none;
  }

  .nw-model-accessories__check-icon {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
  }

  .nw-model-accessories__check-icon svg {
    width: 30px;
    height: 30px;
    color: {{ section.settings.accent_color }};
  }

  .nw-model-accessories__check-text {
    font-family: 'Quando', serif;
    font-size: 18px;
    color: {{ section.settings.text_color }};
    line-height: 28px;
  }

  .nw-model-accessories__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 30px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    font-family: 'Articulat CF', sans-serif;
    font-size: 18px;
    font-weight: 700;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    height: 44px;
    align-self: flex-start;
    margin-top: 10px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .nw-model-accessories__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1200px) {
    .nw-model-accessories__bg,
    .nw-model-accessories__overlay { margin: 0 60px; }
    .nw-model-accessories__content { padding: 100px 110px; }
  }

  @media (max-width: 1024px) {
    .nw-model-accessories { min-height: auto; }
    .nw-model-accessories__bg,
    .nw-model-accessories__overlay { margin: 0 40px; border-radius: 20px; }
    .nw-model-accessories__content {
      padding: 80px 80px;
      min-height: auto;
    }
    .nw-model-accessories__text-col { max-width: 100%; }
    .nw-model-accessories__title { font-size: 34px; line-height: 44px; }
  }

  @media (max-width: 768px) {
    .nw-model-accessories__bg,
    .nw-model-accessories__overlay { margin: 0 20px; border-radius: 15px; }
    .nw-model-accessories__content { padding: 60px 40px; gap: 30px; }
    .nw-model-accessories__title { font-size: 28px; line-height: 38px; }
  }

  @media (max-width: 480px) {
    .nw-model-accessories__bg,
    .nw-model-accessories__overlay { margin: 0 16px; border-radius: 12px; }
    .nw-model-accessories__content { padding: 40px 28px; }
    .nw-model-accessories__title { font-size: 24px; line-height: 34px; }
    .nw-model-accessories__desc { font-size: 16px; line-height: 26px; }
    .nw-model-accessories__check-text { font-size: 16px; line-height: 26px; }
  }
{%- endstyle -%}

<section class="nw-model-accessories">
  <div class="nw-model-accessories__bg">
    {%- if section.settings.background_image != blank -%}
      <img src="{{ section.settings.background_image | image_url: width: 1920 }}" alt="{{ section.settings.heading }}" loading="lazy">
    {%- elsif section.settings.background_image_url != blank -%}
      <img src="{{ section.settings.background_image_url }}" alt="{{ section.settings.heading }}" loading="lazy">
    {%- endif -%}
  </div>
  <div class="nw-model-accessories__overlay"></div>

  <div class="nw-model-accessories__content">
    <div class="nw-model-accessories__text-col">
      <h2 class="nw-model-accessories__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.description != blank -%}
        <p class="nw-model-accessories__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- assign has_checklist = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'item' -%}
          {%- assign has_checklist = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_checklist -%}
        <div class="nw-model-accessories__checklist">
          {%- for block in section.blocks -%}
            {%- if block.type == 'item' -%}
              <div class="nw-model-accessories__check-item" {{ block.shopify_attributes }}>
                <span class="nw-model-accessories__check-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </span>
                <span class="nw-model-accessories__check-text">{{ block.settings.text }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <a href="{{ section.settings.button_link }}" class="nw-model-accessories__btn">{{ section.settings.button_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NW Model Accessories",
  "tag": "section",
  "class": "nw-model-accessories-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Sauna Accessories and Bespoke Upgrades"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Your sauna, your way. Upgrade with premium accessories and bespoke options."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "url",
      "id": "background_image_url",
      "label": "Background Image URL (fallback)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 70,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FCFCFC"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Check Icon Color",
      "default": "#FCFCFC"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#546659"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#FCFCFC"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All Accessories"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Accessory Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Item Text",
          "default": "Harvia 6.0kW heater with rock set"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NW Model Accessories",
      "blocks": [
        { "type": "item", "settings": { "text": "Harvia 6.0kW heater with rock set" } },
        { "type": "item", "settings": { "text": "Interior LED mood lighting" } },
        { "type": "item", "settings": { "text": "Bucket, ladle, and thermometer set" } },
        { "type": "item", "settings": { "text": "Custom color options for door frame" } },
        { "type": "item", "settings": { "text": "Upgraded tempered glass door" } }
      ]
    }
  ]
}
{% endschema %}
