    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Nav Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL"
        }
      ]
    },
    {
      "type": "nav_link_arrow",
      "name": "Nav Link with Arrow",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL"
        }
