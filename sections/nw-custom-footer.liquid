      "default": "Terms & Conditions"
    },
    {
      "type": "url",
      "id": "terms_link",
      "label": "Terms link URL"
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy link text",
      "default": "Privacy Policy"
    },
    {
      "type": "url",
