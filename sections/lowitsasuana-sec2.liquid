<section class="main-section";">
  <div class="video-slider-section">

    

    <div class="section-text-content">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="section-btn">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <div class="video-content">

      {% if section.settings.video_file != blank %}
        {{
          section.settings.video_file
          | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          controls: false
        }}
     {% elsif section.settings.upload_image != blank %}

    <img
      src="{{ section.settings.upload_image | image_url }}"
      alt="section image"
      loading="lazy"
      width=""
      height=""
    >

  {% endif %}


    </div>

  </div>
</section>

<style>


.main-section{
    margin: 0 auto;
    width: 100%;
    display: flex;
    justify-content: center;
    padding-top: 100px;
}

.video-slider-section {
  max-width: 1670px;
  width: 100%;
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 40px;
}


.video-content img{
  position:absolute;
  top:0;
  left:0;
  width:100%;
  height:100%;
  object-fit:cover;
  border-radius:10px;
}



.section-text-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.section-text-content h2 {
  font-size: {{ section.settings.heading_size }}px;
  color: {{ section.settings.heading_color }};
}

.section-text-content p {
  font-size: {{ section.settings.text_size }}px;
  line-height: 1.6;
  color: {{ section.settings.text_color }};
}

.section-btn {
  display: inline-block;
  padding: 12px 30px;
  background-color: {{ section.settings.button_color }};
  color: {{ section.settings.button_text_color }};
  text-decoration: none;
  border-radius: 20px;
  border: 2px solid {{ section.settings.button_border_color }};
  font-weight: bold;
  margin-top: 20px;
  transition: 0.3s;
  width: fit-content;
}

.section-btn:hover {
  background-color: {{ section.settings.button_hover }};
  color: {{ section.settings.button_hover_text }};
  border-color: {{ section.settings.button_border_hover }};
}

.video-content {
  flex: 0 1 588px;
  position: relative;
  border-radius: 10px;
  overflow: hidden;
  min-height: 300px;
}

.video-content video {
  position: absolute;
  top:0;
  left:0;
  width:100%;
  height:100%;
  object-fit:cover;
  border-radius:10px;
}


/* =========================
   RESPONSIVE DESIGN
========================= */

@media (max-width: 1440px){
      .video-content{
    flex: 0 1 400px; /* video can shrink to 500px */

      }

      .video-slider-section{
        padding-left: 40px;
        padding-right: 40px;
      }
}


@media (max-width: 425px){
  .video-slider-section{
    padding-left: 0px;
    padding-right: 0px;
  }

  .video-content{
      flex: 0 1 400px;
  }

   .section-btn {
    width: 0%;
    padding: 0%;
  }
}




/* 1200px se neeche thoda compact */
@media (max-width: 1200px) {
  .main-section {
    padding-top: 80px;
    padding-bottom: 80px;
    padding-left: 40px;
    padding-right: 40px;
  }

  .section-text-content h2 {
    font-size: 28px;
  }

  .section-text-content p {
    font-size: 18px;
  }
}


/* Tablet View */
@media (max-width: 992px) {

  .video-slider-section {
    flex-direction: column;
    gap: 40px;
  }

  .video-content {
    width: 100%;
    {% comment %} flex: unset; {% endcomment %}
    padding-top: 56.25%; /* Proper 16:9 ratio */
  }

  .section-text-content {
    text-align: center;
  }

  .section-btn {
    margin-top: 15px;
  }
}


@media (max-width: 1024px) {
   .video-slider-section{
    padding-left: 0px;
    padding-right: 0px;
  }
}


@media (max-width: 768px) {
   .video-content img{
      object-fit: contain;
  }
}


/* Mobile View */
@media (max-width: 576px) {

  .main-section {
    padding-top: 60px;
    padding-bottom: 60px;
    padding-left: 20px;
    padding-right: 20px;
  }

  .section-text-content h2 {
    font-size: 22px;
  }

  .section-text-content p {
    font-size: 16px;
  }

  .section-btn {
   padding: 14px 30px;
    width: max-content;
  }
}

@media (max-width: 375px) {
     .main-section{
        padding-left: 50px;
    }
}





</style>


{% schema %}
{
  "name": "Video With Text",
  "settings": [

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Loowit Saunas Are Selling Out Quick!"
    },

    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Each project is handcrafted in limited numbers, so a 25% deposit secures your spot. Order your Loowit Sauna today!"
    },

    {
      "type": "video",
      "id": "video_file",
      "label": "Upload Video"
    },

    
    {
       "type": "image_picker",
       "id": "upload_image",
       "label": "Upload Image"
    },

    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Order Now"
    },

    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },


    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 20,
      "max": 60,
      "step": 2,
      "default": 32
    },

    {
      "type": "range",
      "id": "text_size",
      "label": "Text Size",
      "min": 14,
      "max": 30,
      "step": 1,
      "default": 18
    },



    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },

    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },


    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#4A5A4A"
    },

    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },

    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button Border Color",
      "default": "transparent"
    },

    {
      "type": "color",
      "id": "button_border_hover",
      "label": "Button Border Hover Color",
      "default": "#000000"
    },

    {
      "type": "color",
      "id": "button_hover",
      "label": "Button Hover Color",
      "default": "#ffffff"
    },

    {
      "type": "color",
      "id": "button_hover_text",
      "label": "Button Hover Text",
      "default": "#000000"
    },


    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 120
    },

    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 120
    }

  ],
  "presets":[
    {
      "name":"Video With Text"
    }
  ]
}
{% endschema %}
