    "nw_story": {
      "type": "nw-story",
      "settings": {
        "heading": "The Story That Sparked NW Immersion",
        "background_image_url": "https://www.figma.com/api/mcp/asset/720077e1-8bae-471c-8625-2ea9443864c7",
        "text_color": "#FCFCFC",
        "button_text": "Our Story",
        "button_bg": "#546659",
        "button_text_color": "#ffffff"
      },
      "blocks": {
        "para_1": {
          "type": "paragraph",
          "settings": {
            "text": "<p>NW Immersion began with a personal journey. In 2010, founders Michelle and Eric installed their first home sauna. What started as a wellness practice soon became a way of life. For Eric, the change was transformative.</p>"
          }
        },
        "para_2": {
          "type": "paragraph",
          "settings": {
            "text": "<p>Through regular sauna use, he lost 100 pounds and kept it off \u2013 a lasting reminder of the power of heat and cold immersion. Together, Michelle and Eric built NW Immersion on the belief that wellness should be accessible, enjoyable, and deeply rewarding.</p>"
          }
        },
        "para_3": {
          "type": "paragraph",
          "settings": {
            "text": "<p>Today, every sauna we build carries that same commitment: helping you discover health and renewal one session at a time.</p>"
          }
        }
      },
      "block_order": ["para_1", "para_2", "para_3"]
    },
