    "nw_story_HT468t": {
      "type": "nw-story",
      "blocks": {
        "paragraph_gGXaXy": {
          "type": "paragraph",
          "settings": {
            "text": "<p>NW Immersion began with a personal journey. In 2010, founders Michelle and Eric installed their first home sauna. What started as a wellness practice soon became a way of life. For Eric, the change was transformative.</p>"
          }
        },
        "paragraph_BpTgjn": {
          "type": "paragraph",
          "settings": {
            "text": "<p>Through regular sauna use, he lost 100 pounds and kept it off – a lasting reminder of the power of heat and cold immersion. Together, Michelle and Eric built NW Immersion on the belief that wellness should be accessible, enjoyable, and deeply rewarding.</p>"
          }
        },
        "paragraph_wpjLzQ": {
          "type": "paragraph",
          "settings": {
            "text": "<p>Today, every sauna we build carries that same commitment: helping you discover health and renewal one session at a time.</p>"
          }
        }
      },
      "block_order": [
        "paragraph_gGXaXy",
        "paragraph_BpTgjn",
        "paragraph_wpjLzQ"
      ],
