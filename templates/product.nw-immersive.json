      "blocks": {
        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "What size electrical connection does the sauna need?",
            "answer": "<p>The Harvia 6kW heater requires a dedicated 240V / 60A circuit with a GFCI breaker. We strongly recommend having a licensed electrician install the wiring before delivery.</p>"
          }
        },
        "faq_2": {
          "type": "faq_item",
          "settings": {
            "question": "Can the sauna be used in cold winter climates?",
            "answer": "<p>Yes. The 2×6 Canadian Hemlock construction provides excellent thermal insulation, and the Harvia heater is powerful enough to bring the sauna to temperature even in sub-zero winter conditions, typically within 30–45 minutes.</p>"
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Most orders ship within 2–4 weeks. You will receive a tracking number once your order is picked up by the freight carrier. The carrier will contact you to schedule your delivery appointment at your convenience.</p>"
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "Do I need a foundation or concrete pad?",
            "answer": "<p>A level, stable surface is required. A poured concrete pad is ideal, but compacted gravel, pavers, or a well-built deck all work. The surface must be flat to within ¼ inch and properly drained to prevent moisture buildup.</p>"
          }
        },
        "faq_5": {
          "type": "faq_item",
          "settings": {
            "question": "What is the warranty on this sauna?",
            "answer": "<p>5-year structural warranty on the wood frame, 2-year warranty on the Harvia heater, and 1-year parts warranty. As an Authorized Dealer we handle all claims directly and quickly.</p>"
          }
        },
        "faq_6": {
          "type": "faq_item",
          "settings": {
            "question": "How long does assembly take, and do I need professional help?",
            "answer": "<p>Most customers complete assembly in 4–6 hours with 2 people and standard tools (drill, level, wrench). No specialized skills are needed. A licensed electrician is required only for the heater wiring.</p>"
          }
        }
      },
